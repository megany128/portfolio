---
// Faint static starfield that rotates very slowly around the viewport center.
// Sits behind everything else on the welcome scene to give a spacey feel
// without drawing attention.
//
// Dots are pre-generated server-side so layout is stable across loads.

// Deterministic pseudo-random so each server render is identical but varied.
function mulberry32(a: number) {
  return () => {
    a = (a + 0x6d2b79f5) | 0;
    let t = a;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(17);

// Stratified placement: divide area into grid cells, place one star per cell
// with random jitter. Prevents clustering and ensures even coverage from the start.
const cols = 11;
const rows = 10;
const cellW = 150 / cols;
const cellH = 150 / rows;
const stars = Array.from({ length: cols * rows }, (_, i) => {
  const col = i % cols;
  const row = Math.floor(i / cols);
  return {
    x: -25 + col * cellW + rand() * cellW,
    y: -25 + row * cellH + rand() * cellH,
    size: rand() < 0.7 ? 1.5 : rand() < 0.9 ? 2 : 2.5,
    opacity: 0.55 + rand() * 0.4,
    twinkleDelay: rand() * 12,
  };
});
---

<div
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 overflow-hidden"
>
  <!--
    The starfield fills a 150% square that rotates around the viewport center,
    so when the grid spins we never see a hard edge come into view.
  -->
  <div class="starfield absolute top-1/2 left-1/2 w-[150%] h-[150%] -translate-x-1/2 -translate-y-1/2">
    {
      stars.map((s) => (
        <span
          class="star absolute rounded-full bg-white"
          style={`
            left: ${s.x}%;
            top: ${s.y}%;
            width: ${s.size}px;
            height: ${s.size}px;
            opacity: ${s.opacity};
            animation-delay: ${s.twinkleDelay}s;
          `}
        />
      ))
    }
  </div>
</div>

<style is:global>
  @keyframes starfield-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes star-twinkle {
    0%, 100% { opacity: 0.7; }
    50%      { opacity: 1; }
  }

  .starfield {
    animation: starfield-spin 240s linear infinite;
  }

  .star {
    will-change: opacity;
    box-shadow: 0 0 3px rgba(255, 255, 255, 0.7);
    animation: star-twinkle 9s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield, .star { animation: none; }
  }
</style>
