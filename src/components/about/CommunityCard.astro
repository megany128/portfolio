---
interface Props {
  icon: string;
  iconAspect?: string;
  iconWidth?: number;
  iconHeight?: number;
  iconRounded?: boolean;
  title: string;
  description: string;
  photo: string;
}

const {
  icon,
  iconWidth = 19,
  iconHeight = 19,
  iconRounded = true,
  title,
  description,
  photo,
} = Astro.props;
---

<article
  data-community-card
  class="community-card group bg-[var(--color-bg-light)] rounded-[12px] p-4 flex-1 min-w-0 flex flex-col gap-2 relative cursor-default"
>
  <header class="flex items-center gap-2 relative z-[1]">
    <img
      src={icon}
      alt=""
      width={iconWidth}
      height={iconHeight}
      class={iconRounded ? "rounded-[4px] object-cover shrink-0" : "object-contain shrink-0"}
      style={`width: ${iconWidth}px; height: ${iconHeight}px;`}
    />
    <h3 class="font-[family-name:var(--font-display)] font-light text-base text-[var(--color-ink)] leading-tight min-w-0 break-words">
      {title}
    </h3>
  </header>
  <div class="flex flex-col gap-3 relative z-[1]">
    <p class="font-[family-name:var(--font-body)] text-xs text-[var(--color-ink-dim)] leading-snug">
      {description}
    </p>
    <div class="aspect-[1024/683] rounded-[12px] overflow-hidden w-full">
      <img
        src={photo}
        alt=""
        class="community-card__photo size-full object-cover transition-transform duration-[var(--duration-slow)] ease-[var(--ease-out-soft)]"
      />
    </div>
  </div>
</article>

<style>
  .community-card {
    transform: translateY(0);
    transition:
      transform var(--duration-base) var(--ease-out-soft),
      box-shadow var(--duration-base) var(--ease-out-soft),
      opacity var(--duration-base) var(--ease-out-soft),
      filter var(--duration-base) var(--ease-out-soft);
    will-change: transform;
  }
  .community-card:hover {
    transform: translateY(-6px) scale(1.02) rotate(var(--card-tilt, -1.5deg));
    box-shadow: 0 18px 32px -16px rgba(36, 36, 36, 0.35);
    z-index: 2;
  }
  .community-card:nth-child(1) { --card-tilt: -1.5deg; }
  .community-card:nth-child(2) { --card-tilt: 1deg; }
  .community-card:nth-child(3) { --card-tilt: -2deg; }
  .community-card:hover .community-card__photo {
    transform: scale(1.04);
  }

  /* When any card is hovered, siblings dim — matching portrait strip behavior. */
  :global(.flex:has(.community-card:hover)) .community-card:not(:hover) {
    opacity: 0.72;
    filter: saturate(0.9);
    transform: scale(0.985);
  }

  @media (prefers-reduced-motion: reduce) {
    .community-card,
    .community-card__photo,
    .community-card__arrow {
      transition: none !important;
      transform: none !important;
    }
    :global(.flex:has(.community-card:hover)) .community-card:not(:hover) {
      opacity: 1;
      filter: none;
      transform: none;
    }
  }
</style>
