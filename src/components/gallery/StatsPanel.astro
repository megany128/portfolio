---
import type { CardColor } from "../../lib/visitor";
import type { GalleryStats } from "../../lib/visitor-server";

interface Props {
  stats: GalleryStats;
  total: number;
  seedCount: number;
}

const { stats, total, seedCount } = Astro.props;

const displayColors = ["pink", "teal", "green", "orange"] as const;
type DisplayColor = (typeof displayColors)[number];

const colorLabels: Record<DisplayColor, string> = {
  pink: "Pink",
  teal: "Teal",
  green: "Green",
  orange: "Orange",
};

const colorVars: Record<DisplayColor, string> = {
  pink: "var(--color-pink)",
  teal: "var(--color-teal)",
  green: "var(--color-green)",
  orange: "var(--color-orange)",
};

// Merge seed visitors into color counts
const seedColors: CardColor[] = ["teal", "orange", "green", "pink"];
const mergedCounts: Record<DisplayColor, number> = { pink: 0, teal: 0, green: 0, orange: 0 };
for (const c of displayColors) mergedCounts[c] = stats.colorCounts[c] ?? 0;
for (const c of seedColors) mergedCounts[c] = (mergedCounts[c] ?? 0) + 1;

const colorTotal = Object.values(mergedCounts).reduce((a, b) => a + b, 0) || 1;
const seedsWithSig = seedColors.length; // all seed visitors have signatures
const sigTotal = stats.withSignature + seedsWithSig;
const sigPct = total > 0 ? Math.round((sigTotal / total) * 100) : 0;

// Time since latest visitor
const latestDate = stats.latestIssuedAt ? new Date(stats.latestIssuedAt) : null;
const now = new Date();
function timeAgo(d: Date): string {
  const diffMs = now.getTime() - d.getTime();
  const mins = Math.floor(diffMs / 60_000);
  if (mins < 1) return "just now";
  if (mins < 60) return `${mins}min ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}
const latestAgo = latestDate ? timeAgo(latestDate) : null;

const signupTimestamps = stats.signupTimestamps;
---

<details data-stats-panel class="stats-panel mt-2 w-full">
  <summary class="stats-toggle bg-[var(--color-bg-neutral)] rounded-[var(--radius-sm)] px-2 py-1 flex items-center justify-between gap-2 font-[family-name:var(--font-mono)] text-base uppercase text-[var(--color-fg-neutral)] hover:text-[var(--color-ink)] hover:bg-[var(--color-bg-neutral-2)] transition-colors cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
    Stats for Nerds
    <svg class="stats-toggle__chevron transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </summary>

  <div class="stats-body-wrap">
  <div class="stats-body rounded-[var(--radius-md)] border border-[var(--color-bg-neutral-2)] bg-[var(--color-bg-neutral)]/40 mt-4 p-4 sm:p-6 flex flex-col gap-6">

    {/* ---- Visitors over time (client-rendered for local timezone) ---- */}
    <div data-stats-timeline data-timestamps={JSON.stringify(signupTimestamps)} />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      {/* ---- Color distribution ---- */}
      <div>
        <h3 class="font-[family-name:var(--font-mono)] text-xs uppercase text-[var(--color-fg-neutral)] mb-3 tracking-wide">
          Color Picks
        </h3>
        <div class="flex flex-col gap-2">
          {displayColors.map((color) => {
            const count = mergedCounts[color];
            const pct = total > 0 ? Math.round((count / total) * 100) : 0;
            const barW = Math.max(2, (count / colorTotal) * 100);
            return (
              <button
                type="button"
                class="stats-color-row flex items-center gap-2 rounded-[var(--radius-sm)] px-1 -mx-1 transition-colors w-full cursor-pointer"
                data-cursor-bg={color}
                data-stats-color-filter={color}
              >
                <span
                  class="font-[family-name:var(--font-mono)] text-xs uppercase w-16 text-right transition-colors"
                  style={`color: ${colorVars[color]}`}
                >
                  {colorLabels[color]}
                </span>
                <div class="flex-1 h-5 rounded-[var(--radius-sm)] bg-[var(--color-bg-neutral-2)]/50 overflow-hidden">
                  <div
                    class="stats-color-bar h-full rounded-[var(--radius-sm)] motion-safe:transition-all"
                    style={`transition-duration: var(--duration-slow); width: ${barW}%; background: ${colorVars[color]}; opacity: 0.85;`}
                  />
                </div>
                <span class="stats-color-pct font-[family-name:var(--font-mono)] text-xs text-[var(--color-ink-dim)] w-14 tabular-nums transition-colors">
                  {pct}% ({count})
                </span>
              </button>
            );
          })}
        </div>
        <button
          type="button"
          data-stats-filter-reset
          class="font-[family-name:var(--font-mono)] text-[11px] uppercase text-[var(--color-fg-neutral)] hover:text-[var(--color-ink)] transition-all mt-3 cursor-pointer items-center gap-1 ml-[76px]"
          style="display: none"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
            <path d="M3 3v5h5" />
          </svg>
          Show all
        </button>
      </div>

      {/* ---- Quick stats ---- */}
      <div class="grid grid-cols-2 gap-3">
        <div class="stats-card rounded-[var(--radius-md)] bg-[var(--color-bg-neutral)]/60 border border-[var(--color-bg-neutral-2)]/60 p-3">
          <p class="font-[family-name:var(--font-mono)] text-xs uppercase text-[var(--color-fg-neutral)]">Signed Their Card</p>
          <p class="font-[family-name:var(--font-display)] text-2xl font-light text-[var(--color-ink)] mt-1">{sigPct}%</p>
          <p class="font-[family-name:var(--font-mono)] text-[11px] text-[var(--color-ink-mute)]">{sigTotal} of {total}</p>
        </div>

        {latestAgo && (
          <div class="stats-card rounded-[var(--radius-md)] bg-[var(--color-bg-neutral)]/60 border border-[var(--color-bg-neutral-2)]/60 p-3">
            <p class="font-[family-name:var(--font-mono)] text-xs uppercase text-[var(--color-fg-neutral)]">Latest Guest</p>
            <p class="font-[family-name:var(--font-display)] text-2xl font-light text-[var(--color-ink)] mt-1">{latestAgo}</p>
          </div>
        )}

      </div>

    </div>
  </div>
  </div>
</details>

<style>
  /* Color bar row hover — highlight active, fade siblings */
  .stats-color-row {
    padding: 6px 8px;
    margin: -2px -8px;
    transition: opacity var(--duration-fast) var(--ease-out-soft);
  }
  .stats-color-row:hover .stats-color-bar {
    opacity: 1 !important;
  }
  .stats-color-row:hover .stats-color-pct {
    color: var(--color-ink);
  }
  /* Fade non-hovered rows when any row is hovered */
  .flex:has(.stats-color-row:hover) .stats-color-row:not(:hover) {
    opacity: 0.5;
  }
  /* Fade non-active rows when a filter is active */
  .flex:has(.stats-color-row[data-active]) .stats-color-row:not([data-active]) {
    opacity: 0.5;
  }

  .stats-panel .stats-toggle__chevron {
    transition: transform var(--duration-base) var(--ease-out-soft);
  }
  /* Chevron rotated when fully open (not mid-expand, not collapsing) */
  details[open]:not([data-collapsing]):not([data-expanding]) .stats-toggle__chevron {
    transform: rotate(180deg);
  }

  /* Smooth expand/collapse via grid-row trick.
     Default = collapsed (0fr). Only details[open] minus transient states = 1fr. */
  .stats-body-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-slow) var(--ease-out-soft);
  }
  details[open]:not([data-collapsing]):not([data-expanding]) .stats-body-wrap {
    grid-template-rows: 1fr;
  }
  .stats-body {
    overflow: hidden;
    min-height: 0;
    transition: border-color var(--duration-slow) var(--ease-out-soft),
                padding var(--duration-slow) var(--ease-out-soft),
                margin var(--duration-slow) var(--ease-out-soft);
  }
  /* Hide border/padding/margin when collapsed */
  details:not([open]) .stats-body,
  details[data-collapsing] .stats-body,
  details[data-expanding] .stats-body {
    border-color: transparent;
    margin-top: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  /* Active filter button state */
  .stats-color-row[data-active] {
    opacity: 1 !important;
  }
  .stats-color-row[data-active] .stats-color-bar {
    opacity: 1 !important;
  }
  .stats-color-row[data-active] .stats-color-pct {
    color: var(--color-ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .stats-body-wrap,
    .stats-body {
      transition: none;
    }
  }
</style>

<style is:global>
  /* Gallery color filter — hide non-matching cards with FLIP animation via JS */
  [data-gallery-grid] [data-mini-card-wrap] {
    transition: opacity var(--duration-base) var(--ease-out-soft);
  }
  [data-gallery-grid] [data-mini-card-wrap][data-filter-hide] {
    display: none;
  }
</style>

<script>
  function renderTimeline() {
    const container = document.querySelector<HTMLElement>("[data-stats-timeline]");
    if (!container || container.dataset.rendered === "1") return;

    const timestamps: string[] = JSON.parse(container.dataset.timestamps || "[]");
    if (timestamps.length === 0) return;

    // Group by viewer's local day
    const dayMap = new Map<string, number>();
    for (const ts of timestamps) {
      const d = new Date(ts);
      const key = [d.getFullYear(), String(d.getMonth() + 1).padStart(2, "0"), String(d.getDate()).padStart(2, "0")].join("-");
      dayMap.set(key, (dayMap.get(key) ?? 0) + 1);
    }

    const sortedDays = [...dayMap.keys()].sort();
    if (sortedDays.length === 0) return;

    const parseDay = (s: string) => { const [y, m, d] = s.split("-").map(Number); return new Date(y, m - 1, d); };
    const fmtKey = (d: Date) => [d.getFullYear(), String(d.getMonth() + 1).padStart(2, "0"), String(d.getDate()).padStart(2, "0")].join("-");
    const fmtLabel = (s: string) => parseDay(s).toLocaleDateString("en-US", { month: "short", day: "numeric" });

    // Pad 3 empty days before first data so the chart has visual lead-in
    const filled: { day: string; count: number }[] = [];
    const cur = parseDay(sortedDays[0]);
    cur.setDate(cur.getDate() - 3);
    const last = parseDay(sortedDays[sortedDays.length - 1]);
    while (cur <= last) {
      const key = fmtKey(cur);
      filled.push({ day: key, count: dayMap.get(key) ?? 0 });
      cur.setDate(cur.getDate() + 1);
    }
    if (filled.length < 2) return;

    const svgW = 600, svgH = 80, padY = 4;
    const graphH = svgH - padY * 2;
    const max = Math.max(...filled.map((d) => d.count), 1);

    const pts = filled.map((d, i) => ({
      x: (i / (filled.length - 1)) * svgW,
      y: padY + graphH - (d.count / max) * graphH,
      ...d,
    }));

    const linePath = pts.map((p, i) => `${i === 0 ? "M" : "L"}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
    const areaPath = `${linePath} L${pts[pts.length - 1].x.toFixed(1)},${svgH} L${pts[0].x.toFixed(1)},${svgH} Z`;

    const dots = pts.map((p) =>
      `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3" fill="var(--color-teal)" opacity="0" class="stats-line__dot" data-tip-day="${p.day}" data-tip-count="${p.count}" />`
    ).join("");

    container.innerHTML = `
      <h3 class="font-[family-name:var(--font-mono)] text-xs uppercase text-[var(--color-fg-neutral)] mb-3 tracking-wide">Visitors Over Time</h3>
      <div class="flex flex-col gap-1">
        <svg viewBox="0 0 ${svgW} ${svgH}" preserveAspectRatio="none" class="w-full h-20" data-stats-line role="img" aria-label="Visitor signups over time: ${filled.length} days, peak ${max} in a day">
          <path d="${areaPath}" fill="var(--color-teal)" opacity="0.12" />
          <path d="${linePath}" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" opacity="0.7" />
          <line data-stats-crosshair x1="0" y1="0" x2="0" y2="${svgH}" stroke="var(--color-ink-mute)" stroke-width="1" stroke-dasharray="3 3" opacity="0" />
          <circle data-stats-active-dot cx="0" cy="0" r="4.5" fill="var(--color-teal)" stroke="var(--color-bg)" stroke-width="2" opacity="0" />
          ${dots}
        </svg>
        <div class="flex justify-between font-[family-name:var(--font-mono)] text-[10px] text-[var(--color-ink-mute)]">
          <span>${fmtLabel(filled[0].day)}</span>
          <span>${fmtLabel(filled[filled.length - 1].day)}</span>
        </div>
      </div>
      <div data-stats-tooltip class="fixed px-1.5 py-0.5 rounded-[var(--radius-sm)] bg-[var(--color-ink)] text-[var(--color-ink-inverted)] font-[family-name:var(--font-mono)] text-[10px] whitespace-nowrap pointer-events-none opacity-0 transition-opacity z-50"></div>`;
    container.dataset.rendered = "1";
  }

  function wireStatsPanel() {
    renderTimeline();

    // Smooth open/close — intercept native <details> toggle
    const details = document.querySelector<HTMLDetailsElement>("[data-stats-panel]");
    const summary = details?.querySelector<HTMLElement>("summary");
    const wrap = details?.querySelector<HTMLElement>(".stats-body-wrap");
    if (details && summary && wrap && !details.dataset.statsWired) {
      details.dataset.statsWired = "1";
      const DURATION = 480;
      let animating = false;

      summary.addEventListener("click", (e) => {
        e.preventDefault();
        if (animating) return;

        if (details.open) {
          // Collapse: add collapsing flag, let CSS transition to 0fr, then remove open
          animating = true;
          details.setAttribute("data-collapsing", "");
          wrap.addEventListener("transitionend", function onEnd(ev) {
            if (ev.target !== wrap) return;
            wrap.removeEventListener("transitionend", onEnd);
            details.removeAttribute("data-collapsing");
            details.open = false;
            animating = false;
          }, { once: false });
          // Safety timeout in case transitionend doesn't fire
          setTimeout(() => {
            if (animating) {
              details.removeAttribute("data-collapsing");
              details.open = false;
              animating = false;
            }
          }, DURATION + 50);
        } else {
          // Expand: set open first (so content exists), then trigger transition
          animating = true;
          details.setAttribute("data-expanding", "");
          details.open = true;
          // Force reflow so the 0fr state is captured before transitioning to 1fr
          wrap.offsetHeight;
          details.removeAttribute("data-expanding");
          wrap.addEventListener("transitionend", function onEnd(ev) {
            if (ev.target !== wrap) return;
            wrap.removeEventListener("transitionend", onEnd);
            animating = false;
          }, { once: false });
          setTimeout(() => { animating = false; }, DURATION + 50);
        }
      });
    }

    // Color filter — click a color row to filter gallery cards with FLIP animation
    const grid = document.querySelector<HTMLElement>("[data-gallery-grid]");
    const filterBtns = document.querySelectorAll<HTMLButtonElement>("[data-stats-color-filter]");
    const resetBtn = document.querySelector<HTMLButtonElement>("[data-stats-filter-reset]");
    const reduced = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
    if (grid && filterBtns.length) {
      let activeColor: string | null = null;
      let filtering = false;

      function showReset(show: boolean) {
        if (!resetBtn) return;
        resetBtn.style.display = show ? "inline-flex" : "none";
      }

      function applyFilter(color: string | null) {
        if (filtering) return;
        filtering = true;
        showReset(!!color);

        const cards = Array.from(grid!.querySelectorAll<HTMLElement>("[data-mini-card-wrap]"));
        const fadeDur = reduced ? 0 : 180;
        const flipDur = reduced ? 0 : 360;

        // Currently visible cards
        const visible = cards.filter((c) => !c.hasAttribute("data-filter-hide"));

        // Which cards should be visible after?
        const shouldShow = (c: HTMLElement) => !color || c.dataset.color === color;

        // Cards to fade out (currently visible but won't be after)
        const toFadeOut = visible.filter((c) => !shouldShow(c));
        // Cards that stay visible
        const stayers = visible.filter((c) => shouldShow(c));
        // Cards to reveal (currently hidden but should show)
        const toReveal = cards.filter((c) => c.hasAttribute("data-filter-hide") && shouldShow(c));

        // FIRST — capture positions of cards that will stay
        const firstRects = new Map<HTMLElement, DOMRect>();
        for (const c of stayers) firstRects.set(c, c.getBoundingClientRect());

        function afterFadeOut() {
          // Apply hide/show
          for (const c of cards) {
            if (shouldShow(c)) {
              c.removeAttribute("data-filter-hide");
            } else {
              c.setAttribute("data-filter-hide", "");
            }
          }

          // LAST — capture new positions
          const nowVisible = cards.filter((c) => !c.hasAttribute("data-filter-hide"));
          const lastRects = new Map<HTMLElement, DOMRect>();
          for (const c of nowVisible) lastRects.set(c, c.getBoundingClientRect());

          // INVERT + PLAY
          let pending = 0;
          for (const c of nowVisible) {
            const first = firstRects.get(c);
            const last = lastRects.get(c)!;

            if (first) {
              const dx = first.left - last.left;
              const dy = first.top - last.top;
              if (Math.abs(dx) < 1 && Math.abs(dy) < 1) {
                if (toReveal.includes(c)) {
                  pending++;
                  const a = c.animate([{ opacity: 0, transform: "scale(0.92)" }, { opacity: 1, transform: "scale(1)" }], { duration: flipDur, easing: "cubic-bezier(0.22, 1, 0.36, 1)" });
                  a.onfinish = () => { pending--; if (!pending) filtering = false; };
                }
                continue;
              }
              pending++;
              const a = c.animate(
                [{ transform: `translate(${dx}px, ${dy}px)` }, { transform: "translate(0, 0)" }],
                { duration: flipDur, easing: "cubic-bezier(0.22, 1, 0.36, 1)" },
              );
              a.onfinish = () => { pending--; if (!pending) filtering = false; };
            } else {
              // Newly visible — fade + scale in
              pending++;
              const a = c.animate(
                [{ opacity: 0, transform: "scale(0.92)" }, { opacity: 1, transform: "scale(1)" }],
                { duration: flipDur, easing: "cubic-bezier(0.22, 1, 0.36, 1)" },
              );
              a.onfinish = () => { pending--; if (!pending) filtering = false; };
            }
          }
          if (!pending) filtering = false;
        }

        // Safety timeout — unlock filtering if animations don't finish
        setTimeout(() => { filtering = false; }, fadeDur + flipDur + 100);

        if (toFadeOut.length === 0) {
          afterFadeOut();
        } else {
          let done = 0;
          for (const c of toFadeOut) {
            const a = c.animate(
              [{ opacity: 1, transform: "scale(1)" }, { opacity: 0, transform: "scale(0.92)" }],
              { duration: fadeDur, easing: "ease-out" },
            );
            a.onfinish = () => { done++; if (done >= toFadeOut.length) afterFadeOut(); };
          }
        }
      }

      function clearFilter() {
        activeColor = null;
        filterBtns.forEach((b) => b.removeAttribute("data-active"));
        applyFilter(null);
      }

      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const color = btn.dataset.statsColorFilter!;
          if (activeColor === color) {
            clearFilter();
          } else {
            activeColor = color;
            filterBtns.forEach((b) => {
              b.toggleAttribute("data-active", b.dataset.statsColorFilter === color);
            });
            applyFilter(activeColor);
          }
        });
      });

      resetBtn?.addEventListener("click", clearFilter);
    }

    // Line graph hover: crosshair + active dot + tooltip
    const svg = document.querySelector<SVGElement>("[data-stats-line]");
    const tip = document.querySelector<HTMLElement>("[data-stats-tooltip]");
    const crosshair = svg?.querySelector<SVGLineElement>("[data-stats-crosshair]");
    const activeDot = svg?.querySelector<SVGCircleElement>("[data-stats-active-dot]");
    if (svg && tip && crosshair && activeDot) {
      const fmtDate = (iso: string) => {
        const [y, m, d] = iso.split("-").map(Number);
        return new Date(y, m - 1, d).toLocaleDateString("en-US", { month: "short", day: "numeric" });
      };

      svg.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = svg.getBoundingClientRect();
        const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        const dots = svg.querySelectorAll<SVGCircleElement>(".stats-line__dot");
        if (dots.length === 0) return;
        const idx = Math.round(ratio * (dots.length - 1));
        const dot = dots[Math.max(0, Math.min(idx, dots.length - 1))];
        const cx = dot.cx.baseVal.value;
        const cy = dot.cy.baseVal.value;

        // Position crosshair line
        crosshair.setAttribute("x1", String(cx));
        crosshair.setAttribute("x2", String(cx));
        crosshair.style.opacity = "0.3";

        // Position active dot
        activeDot.setAttribute("cx", String(cx));
        activeDot.setAttribute("cy", String(cy));
        activeDot.style.opacity = "1";

        // Tooltip
        const count = dot.dataset.tipCount;
        const label = count === "1" ? "visitor" : "visitors";
        tip.textContent = `${fmtDate(dot.dataset.tipDay!)} · ${count} ${label}`;
        tip.style.opacity = "1";
        tip.style.left = `${e.clientX}px`;
        tip.style.top = `${rect.top - 28}px`;
        tip.style.transform = "translateX(-50%)";
      });

      svg.addEventListener("mouseleave", () => {
        tip.style.opacity = "0";
        crosshair.style.opacity = "0";
        activeDot.style.opacity = "0";
      });
    }
  }
  wireStatsPanel();
  document.addEventListener("astro:page-load", wireStatsPanel);
</script>
