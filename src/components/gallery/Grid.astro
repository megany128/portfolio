---
import MiniLibraryCard from "./MiniLibraryCard.astro";
import type { VisitorRecord } from "../../lib/visitor-server";

interface Props {
  visitors: VisitorRecord[];
  youId?: string;
  /** Center cards horizontally when there aren't enough to fill a row. */
  centered?: boolean;
  /** Total number of real (non-seed) visitors in the DB. Enables "Load more". */
  totalReal?: number;
  /** Number of real visitors fetched per page. */
  pageSize?: number;
}

const { visitors, youId, centered = false, totalReal, pageSize = 48 } = Astro.props;
---

<div
  data-gallery-grid
  data-you-id={youId ?? ""}
  data-offset={pageSize}
  data-page-size={pageSize}
  data-total-real={totalReal ?? 0}
  class:list={[
    "gallery-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-6 sm:gap-y-8 gap-x-4 w-full",
  ]}
>
  {
    visitors.map((v) => (
      <MiniLibraryCard
        id={v.id}
        name={v.name}
        color={v.color}
        number={v.number}
        issuedAt={v.issuedAt}
        isYou={v.id === youId}
        signature={v.signature}
      />
    ))
  }
</div>

{/* "Load more" button — hidden when all cards are loaded. */}
{(totalReal ?? 0) > pageSize && (
  <button
    type="button"
    data-gallery-load-more
    class="gallery-load-more self-center mt-2 bg-[var(--color-bg-neutral)] rounded-[4px] px-4 py-2 flex items-center gap-2 font-[family-name:var(--font-mono)] text-base uppercase text-[var(--color-fg-neutral)] hover:text-[var(--color-ink)] hover:bg-[var(--color-bg-neutral-2)] transition-colors"
  >
    Load more
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </button>
)}

<!-- Detail modal — blurred backdrop + a container the grid animates a clone into. -->
<div
  data-gallery-detail
  class="gallery-detail fixed inset-0 z-[100] pointer-events-none opacity-0"
  aria-hidden="true"
>
  <div
    data-gallery-backdrop
    class="gallery-detail__backdrop absolute inset-0 bg-black/30 backdrop-blur-md opacity-0 transition-opacity duration-300"
  ></div>
  <button
    data-gallery-close
    type="button"
    aria-label="Close"
    class="gallery-detail__close absolute top-6 right-6 z-[2] size-10 grid place-items-center rounded-full bg-white/80 text-[var(--color-ink)] hover:bg-white transition-colors shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6L6 18" />
      <path d="M6 6l12 12" />
    </svg>
  </button>
  <button
    data-gallery-prev
    type="button"
    aria-label="Previous card"
    class="gallery-detail__nav gallery-detail__nav--prev absolute left-6 top-1/2 -translate-y-1/2 z-[2] size-10 grid place-items-center rounded-full bg-white/80 text-[var(--color-ink)] hover:bg-white transition-colors shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>
  <button
    data-gallery-next
    type="button"
    aria-label="Next card"
    class="gallery-detail__nav gallery-detail__nav--next absolute right-6 top-1/2 -translate-y-1/2 z-[2] size-10 grid place-items-center rounded-full bg-white/80 text-[var(--color-ink)] hover:bg-white transition-colors shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </button>
  <div
    data-gallery-you-actions
    class="gallery-detail__you-actions absolute left-1/2 -translate-x-1/2 z-[2] flex items-center gap-2 opacity-0 pointer-events-none"
    style="bottom: max(24px, env(safe-area-inset-bottom, 0px) + 16px);"
  >
    <a
      data-gallery-edit
      href="/onboarding?edit"
      class="gallery-detail__edit flex items-center gap-2 px-3 py-2 rounded-[10px] bg-white/80 hover:bg-white text-[var(--color-ink)] font-[family-name:var(--font-mono)] text-sm uppercase shadow-[0_4px_12px_rgba(0,0,0,0.15)] transition-colors"
    >
      Edit card
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
        <path d="m15 5 4 4" />
      </svg>
    </a>
    <button
      data-gallery-delete
      type="button"
      class="gallery-detail__delete flex items-center gap-2 px-3 py-2 rounded-[10px] bg-white/80 hover:bg-red-50 text-[var(--color-ink)] hover:text-red-600 font-[family-name:var(--font-mono)] text-sm uppercase shadow-[0_4px_12px_rgba(0,0,0,0.15)] transition-colors"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18" />
        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" />
        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
      </svg>
      Delete
    </button>
  </div>
  <button
    data-gallery-report
    type="button"
    class="gallery-detail__report absolute left-1/2 -translate-x-1/2 z-[2] flex items-center gap-2 px-3 py-2 rounded-[10px] bg-white/80 hover:bg-white text-[var(--color-ink)] font-[family-name:var(--font-mono)] text-sm uppercase shadow-[0_4px_12px_rgba(0,0,0,0.15)] transition-colors opacity-0 pointer-events-none"
    style="bottom: max(24px, env(safe-area-inset-bottom, 0px) + 16px);"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
      <line x1="4" x2="4" y1="22" y2="15" />
    </svg>
    Report
  </button>
  <div
    data-gallery-stage
    class="gallery-detail__stage absolute inset-0 pointer-events-none"
    style="perspective: 1400px;"
  ></div>
</div>

<style is:global>
  .gallery-detail {
    transition: opacity 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .gallery-detail[data-open] {
    opacity: 1;
    pointer-events: auto;
  }
  .gallery-detail[data-open] .gallery-detail__backdrop,
  .gallery-detail[data-open] .gallery-detail__close,
  .gallery-detail[data-open] .gallery-detail__nav {
    opacity: 1;
  }
  .gallery-detail[data-open][data-is-you] .gallery-detail__you-actions {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 300ms cubic-bezier(0.22, 1, 0.36, 1) 200ms;
  }
  /* Report button: visible when detail is open, card is NOT yours, AND viewer is signed in. */
  .gallery-detail[data-open][data-can-report]:not([data-is-you]) .gallery-detail__report {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 300ms cubic-bezier(0.22, 1, 0.36, 1) 200ms;
  }

  /* Large detail card — reuses the mini-card visual system but scaled up so
     the signature and typography read clearly in the centered spotlight. */
  .gallery-detail__stage [data-mini-card-wrap] {
    position: absolute;
    transform-origin: top left;
    transition: none;
  }
  .gallery-detail__stage .mini-card {
    cursor: default;
  }
  /* Suppress grid hover effects in the detail stage — tilt/gloss handled via JS. */
  .gallery-detail__stage .mini-card-wrap:hover .mini-card {
    box-shadow: none;
  }
  .gallery-detail__stage .mini-card-wrap:hover .mini-gloss {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .mini-card-wrap,
    .mini-card {
      transition: none !important;
    }
  }
</style>

<script>
  /*
    Visitor-gallery interactions:
      1. Hover  — scale + 3D parallax tilt that tracks the cursor, plus a
                  cursor-following glossy highlight. Springs back on leave.
      2. Click  — FLIP animation into a centered large detail view with a
                  blurred backdrop. Reversal on close uses the same spring.
      3. Shuffle — staggered FLIP reorder. The current visitor (if any) has
                  an ~80% chance of landing in the top-6 positions.
  */

  function wireGallery() {
  const grid = document.querySelector<HTMLElement>("[data-gallery-grid]");
  const detail = document.querySelector<HTMLElement>("[data-gallery-detail]");
  const stage = detail?.querySelector<HTMLElement>("[data-gallery-stage]");
  const backdrop = detail?.querySelector<HTMLElement>("[data-gallery-backdrop]");
  const closeBtn = detail?.querySelector<HTMLButtonElement>("[data-gallery-close]");

  if (!grid || !detail || !stage || !backdrop || !closeBtn) {
    return;
  }
  if (grid.dataset.galleryWired === "1") return;
  grid.dataset.galleryWired = "1";
  {
    // Read youId fresh each time — the client-side identity fallback
    // (patchGalleryIdentity) may set it after wireGallery runs.
    const getYouId = () => grid.dataset.youId || null;
    const reduced = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.innerWidth < 640 || "ontouchstart" in window;

    const SPRING_EASE = "cubic-bezier(0.34, 1.56, 0.64, 1)";

    /* ---------- lazy signature loading -------------------------------- */
    // Gallery cards ship without signature data to keep initial HTML small.
    // Fetch on detail open and inject into the clone.
    const sigCache = new Map<string, string | null>();

    async function lazyLoadSignature(clone: HTMLElement, cardId: string | undefined) {
      if (!cardId) return;
      // Seed visitors have inline signatures already — skip.
      if (cardId.startsWith("seed-")) return;
      // Check cache first.
      if (sigCache.has(cardId)) {
        const cached = sigCache.get(cardId)!;
        if (cached) injectSignature(clone, cached);
        return;
      }
      try {
        const res = await fetch(`/api/signature/${cardId}`);
        if (!res.ok) { sigCache.set(cardId, null); return; }
        const dataUrl = await res.text();
        sigCache.set(cardId, dataUrl);
        injectSignature(clone, dataUrl);
      } catch {
        sigCache.set(cardId, null);
      }
    }

    function injectSignature(el: HTMLElement, dataUrl: string) {
      const card = el.querySelector<HTMLElement>(".library-card");
      if (!card) return;
      if (card.querySelector(".library-card__signature")) return;
      const fallback = card.querySelector<HTMLElement>(".library-card__fallback-sig");
      const img = document.createElement("img");
      img.src = dataUrl;
      img.alt = "signature";
      img.className = "library-card__signature absolute inset-0 w-full h-full object-contain pointer-events-none";
      img.loading = "eager";
      img.decoding = "async";
      // Remove fallback only after the signature image has decoded so there
      // is no flash of empty space between the two.
      if (fallback) img.onload = () => fallback.remove();
      card.appendChild(img);
    }

    /* ---------- hover tilt + gloss (delegated) ------------------------- */
    // Single grid-level listeners instead of per-card to avoid 200+ listeners.
    type TiltState = { raf: number; pending: { x: number; y: number } | null };
    const tiltStates = new WeakMap<HTMLElement, TiltState>();

    function applyTilt(wrap: HTMLElement, state: TiltState) {
      state.raf = 0;
      if (!state.pending) return;
      const rect = wrap.getBoundingClientRect();
      const px = (state.pending.x - rect.left) / rect.width;
      const py = (state.pending.y - rect.top) / rect.height;
      const rotY = (px - 0.5) * 16;
      const rotX = (0.5 - py) * 16;
      wrap.style.transform = `perspective(1000px) scale(1.04) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg)`;
      const gloss = wrap.querySelector<HTMLElement>("[data-mini-gloss]");
      if (gloss) {
        gloss.style.setProperty("--gloss-x", `${(px * 100).toFixed(1)}%`);
        gloss.style.setProperty("--gloss-y", `${(py * 100).toFixed(1)}%`);
      }
    }

    function getTiltState(wrap: HTMLElement): TiltState {
      let s = tiltStates.get(wrap);
      if (!s) { s = { raf: 0, pending: null }; tiltStates.set(wrap, s); }
      return s;
    }

    if (!isMobile) {
      let hoveredWrap: HTMLElement | null = null;

      function resetTilt(wrap: HTMLElement) {
        const state = tiltStates.get(wrap);
        if (state) {
          state.pending = null;
          if (state.raf) { cancelAnimationFrame(state.raf); state.raf = 0; }
        }
        delete wrap.dataset.tilting;
        wrap.style.transform = "";
      }

      grid.addEventListener("mousemove", (e: MouseEvent) => {
        const wrap = (e.target as HTMLElement).closest<HTMLElement>("[data-mini-card-wrap]");

        // If mouse moved to a different card (or off all cards), reset the old one.
        if (hoveredWrap && hoveredWrap !== wrap) {
          resetTilt(hoveredWrap);
          hoveredWrap = null;
        }

        if (!wrap || wrap.dataset.flying !== undefined) return;
        hoveredWrap = wrap;
        const state = getTiltState(wrap);
        state.pending = { x: e.clientX, y: e.clientY };
        wrap.dataset.tilting = "";
        if (!state.raf) state.raf = requestAnimationFrame(() => applyTilt(wrap, state));
      });

      // Reset when mouse leaves the grid entirely.
      grid.addEventListener("mouseleave", () => {
        if (hoveredWrap) {
          resetTilt(hoveredWrap);
          hoveredWrap = null;
        }
      });
    }

    // Delegated click handler for card detail.
    grid.addEventListener("click", (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest("[data-gallery-close]")) return;
      const wrap = (e.target as HTMLElement).closest<HTMLElement>("[data-mini-card-wrap]");
      if (wrap) openDetail(wrap);
    });

    /* ---------- click → FLIP detail view ------------------------------- */
    type OpenState = {
      source: HTMLElement;
      clone: HTMLElement;
      startRect: DOMRect;
      targetRect: { left: number; top: number; width: number; height: number };
      scale: number;
    };
    let open: OpenState | null = null;

    const DETAIL_SCALE = 1.7;

    const computeTarget = (rect: DOMRect) => {
      // Center the clone on screen, clamped so it doesn't overflow. Padding
      // shrinks on narrow viewports so the card uses the available width.
      const pad = window.innerWidth < 640 ? 24 : 80;
      const maxW = Math.min(window.innerWidth - pad, rect.width * DETAIL_SCALE);
      const maxH = Math.min(window.innerHeight - pad, rect.height * DETAIL_SCALE);
      // Below 640px, allow scales under 1.1 so the detail card actually
      // fits inside the viewport instead of overflowing horizontally.
      const minScale = window.innerWidth < 640 ? 0.85 : 1.1;
      const scale = Math.max(
        minScale,
        Math.min(DETAIL_SCALE, maxW / rect.width, maxH / rect.height),
      );
      const width = rect.width * scale;
      const height = rect.height * scale;
      return {
        left: window.innerWidth / 2 - width / 2,
        top: window.innerHeight / 2 - height / 2,
        width,
        height,
        scale,
      };
    };

    /**
     * Build a centered, scaled clone of a card and append it to the stage.
     * Uses transform-origin: 50% 50% so subsequent hover rotations pivot
     * around the card's center rather than its top-left corner.
     */
    const buildClone = (source: HTMLElement, scale: number, initialOpacity = 1, initialOffsetX = 0): HTMLElement => {
      const rect = source.getBoundingClientRect();
      const W = rect.width;
      const H = rect.height;
      const left = window.innerWidth / 2 - W / 2;
      const top = window.innerHeight / 2 - H / 2;

      const clone = source.cloneNode(true) as HTMLElement;
      clone.dataset.flying = "";
      delete clone.dataset.tilting;
      clone.style.position = "absolute";
      clone.style.transformOrigin = "50% 50%";
      clone.style.width = `${W}px`;
      clone.style.height = `${H}px`;
      clone.style.left = `${left}px`;
      clone.style.top = `${top}px`;
      clone.style.transform = initialOffsetX
        ? `perspective(1200px) scale(${scale}) translateX(${initialOffsetX}px)`
        : `perspective(1200px) scale(${scale})`;
      clone.style.opacity = String(initialOpacity);
      clone.style.pointerEvents = "auto";
      clone.style.cursor = "default";
      stage!.appendChild(clone);
      return clone;
    };

    /**
     * Hover handler for the open detail clone — preserves the detail scale,
     * adds tilt around the card's center, and tracks the cursor for gloss.
     * Removed when navigating away or closing.
     */
    type DetailHover = { remove: () => void };
    const attachDetailHover = (clone: HTMLElement, baseScale: number): DetailHover => {
      let raf = 0;
      let pending: { x: number; y: number } | null = null;
      const gloss = clone.querySelector<HTMLElement>("[data-mini-gloss]");
      let active = true;

      const apply = () => {
        raf = 0;
        if (!pending || !active) return;
        const rect = clone.getBoundingClientRect();
        const px = (pending.x - rect.left) / rect.width;
        const py = (pending.y - rect.top) / rect.height;
        const rotY = (px - 0.5) * 12;
        const rotX = (0.5 - py) * 12;
        clone.style.transform = `perspective(1200px) scale(${baseScale}) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg)`;
        if (gloss) {
          gloss.style.opacity = "1";
          gloss.style.setProperty("--gloss-x", `${(px * 100).toFixed(1)}%`);
          gloss.style.setProperty("--gloss-y", `${(py * 100).toFixed(1)}%`);
        }
      };

      const onMove = (e: MouseEvent) => {
        pending = { x: e.clientX, y: e.clientY };
        if (!raf) raf = requestAnimationFrame(apply);
      };
      const onLeave = () => {
        pending = null;
        if (raf) cancelAnimationFrame(raf);
        raf = 0;
        if (!active) return;
        clone.style.transform = `perspective(1200px) scale(${baseScale})`;
        if (gloss) gloss.style.opacity = "0";
      };
      clone.addEventListener("mousemove", onMove);
      clone.addEventListener("mouseleave", onLeave);
      return {
        remove: () => {
          active = false;
          if (raf) cancelAnimationFrame(raf);
          clone.removeEventListener("mousemove", onMove);
          clone.removeEventListener("mouseleave", onLeave);
        },
      };
    };

    let openHover: DetailHover | null = null;

    const openDetail = (wrap: HTMLElement) => {
      if (open) return;
      const startRect = wrap.getBoundingClientRect();
      const target = computeTarget(startRect);
      const W = startRect.width;
      const H = startRect.height;

      // Center-origin clone — start positioned over the source at scale 1,
      // then animate scale up to target. With origin: 50% 50%, the visual
      // center stays put during scaling; we just need the layout box (left,
      // top) at the right place for both endpoints.
      const startLeft = startRect.left;
      const startTop = startRect.top;
      const endLeft = window.innerWidth / 2 - W / 2;
      const endTop = window.innerHeight / 2 - H / 2;

      const clone = wrap.cloneNode(true) as HTMLElement;
      clone.dataset.flying = "";
      delete clone.dataset.tilting;
      clone.style.position = "absolute";
      clone.style.transformOrigin = "50% 50%";
      clone.style.width = `${W}px`;
      clone.style.height = `${H}px`;
      clone.style.left = `${startLeft}px`;
      clone.style.top = `${startTop}px`;
      clone.style.transform = `perspective(1200px) scale(1)`;
      clone.style.pointerEvents = "auto";
      clone.style.cursor = "default";
      stage!.appendChild(clone);
      wrap.style.visibility = "hidden";
      detail!.setAttribute("data-open", "");
      detail!.setAttribute("aria-hidden", "false");
      // Show edit button only when viewing your own card.
      // Show report button when signed in and viewing someone else's card.
      const cardId = wrap.dataset.id;
      if (cardId && cardId === getYouId()) {
        detail!.setAttribute("data-is-you", "");
      } else {
        detail!.removeAttribute("data-is-you");
      }
      if (getYouId()) {
        detail!.setAttribute("data-can-report", "");
      } else {
        detail!.removeAttribute("data-can-report");
      }

      open = {
        source: wrap,
        clone,
        startRect,
        targetRect: { left: endLeft, top: endTop, width: W * target.scale, height: H * target.scale },
        scale: target.scale,
      };

      // Lazy-load signature — gallery cards don't ship with signature data to
      // keep the HTML payload small. Fetch it when the detail view opens.
      lazyLoadSignature(clone, cardId);

      const keyframes: Keyframe[] = [
        {
          left: `${startLeft}px`,
          top: `${startTop}px`,
          transform: `perspective(1200px) scale(1)`,
        },
        {
          left: `${endLeft}px`,
          top: `${endTop}px`,
          transform: `perspective(1200px) scale(${target.scale})`,
        },
      ];
      const anim = clone.animate(keyframes, {
        duration: reduced ? 0 : isMobile ? 200 : 520,
        easing: isMobile ? "ease-out" : SPRING_EASE,
        fill: "forwards",
      });
      anim.onfinish = () => {
        // Cancel fill:forwards so inline styles (hover tilt) can take effect.
        clone.style.left = `${endLeft}px`;
        clone.style.top = `${endTop}px`;
        clone.style.transform = `perspective(1200px) scale(${target.scale})`;
        try { anim.cancel(); } catch {}
        if (!isMobile) openHover = attachDetailHover(clone, target.scale);
      };
    };

    /** Slide-swap to the next/prev card while staying in detail mode. */
    const navigateDetail = (dir: 1 | -1) => {
      if (!open) return;
      const o = open;

      const cards = Array.from(grid!.children).filter(
        (n): n is HTMLElement => n instanceof HTMLElement,
      );
      const currentIdx = cards.indexOf(o.source);
      if (currentIdx === -1) return;
      const nextIdx = (currentIdx + dir + cards.length) % cards.length;
      const nextSource = cards[nextIdx];
      if (nextSource === o.source) return;

      // Tear down old hover so it doesn't fight the exit animation.
      openHover?.remove();
      openHover = null;

      // Restore old source visibility, hide the next one (it's about to take
      // the spotlight). Hide AFTER cloning below to avoid cloning hidden state.
      o.source.style.visibility = "";

      // Direction convention: pressing → moves the deck leftward — old card
      // exits to the left, new card enters from the right.
      const slidePx = 80;
      const exitOffset = -dir * slidePx;
      const enterOffset = dir * slidePx;

      const oldClone = o.clone;
      const exitAnim = oldClone.animate(
        [
          { opacity: 1, transform: `perspective(1200px) scale(${o.scale}) translateX(0px)` },
          { opacity: 0, transform: `perspective(1200px) scale(${o.scale}) translateX(${exitOffset}px)` },
        ],
        {
          duration: reduced ? 0 : isMobile ? 120 : 240,
          easing: "cubic-bezier(0.4, 0, 1, 1)",
          fill: "forwards",
        },
      );
      exitAnim.onfinish = () => oldClone.remove();

      const nextRect = nextSource.getBoundingClientRect();
      const nextTarget = computeTarget(nextRect);
      const newClone = buildClone(nextSource, nextTarget.scale, 0, enterOffset);
      nextSource.style.visibility = "hidden";

      const enterAnim = newClone.animate(
        [
          { opacity: 0, transform: `perspective(1200px) scale(${nextTarget.scale}) translateX(${enterOffset}px)` },
          { opacity: 1, transform: `perspective(1200px) scale(${nextTarget.scale}) translateX(0px)` },
        ],
        {
          duration: reduced ? 0 : isMobile ? 150 : 320,
          easing: isMobile ? "ease-out" : SPRING_EASE,
          fill: "forwards",
        },
      );
      enterAnim.onfinish = () => {
        // Cancel fill:forwards so inline tilt transforms can take effect.
        newClone.style.opacity = "1";
        newClone.style.transform = `perspective(1200px) scale(${nextTarget.scale})`;
        try { enterAnim.cancel(); } catch {}
        openHover = attachDetailHover(newClone, nextTarget.scale);
      };

      // Lazy-load signature for the new card.
      const nextId = nextSource.dataset.id;
      lazyLoadSignature(newClone, nextId);

      // Update edit/report button visibility for the new card.
      if (nextId && nextId === getYouId()) {
        detail!.setAttribute("data-is-you", "");
      } else {
        detail!.removeAttribute("data-is-you");
      }
      if (getYouId()) {
        detail!.setAttribute("data-can-report", "");
      } else {
        detail!.removeAttribute("data-can-report");
      }
      resetReportBtn();
      resetDeleteBtn();

      open = {
        source: nextSource,
        clone: newClone,
        startRect: nextRect,
        targetRect: {
          left: window.innerWidth / 2 - nextRect.width / 2,
          top: window.innerHeight / 2 - nextRect.height / 2,
          width: nextRect.width * nextTarget.scale,
          height: nextRect.height * nextTarget.scale,
        },
        scale: nextTarget.scale,
      };
    };

    const closeDetail = () => {
      if (!open) return;
      const o = open;
      open = null;
      openHover?.remove();
      openHover = null;
      resetReportBtn();
      resetDeleteBtn();

      // Reset transform to the un-tilted scaled state before measuring so the
      // close animation starts from a known orientation.
      o.clone.style.transform = `perspective(1200px) scale(${o.scale})`;

      const sourceRect = o.source.getBoundingClientRect();
      const W = parseFloat(o.clone.style.width);
      const H = parseFloat(o.clone.style.height);
      const currentLeft = parseFloat(o.clone.style.left);
      const currentTop = parseFloat(o.clone.style.top);
      const endLeft = sourceRect.left + sourceRect.width / 2 - W / 2;
      const endTop = sourceRect.top + sourceRect.height / 2 - H / 2;

      // Animate clone back to grid slot at grid scale (0.72) so it matches
      // the source size exactly when it lands.
      const gridScale = 0.72;
      const keyframes: Keyframe[] = [
        {
          left: `${currentLeft}px`,
          top: `${currentTop}px`,
          transform: `perspective(1200px) scale(${o.scale})`,
        },
        {
          left: `${endLeft}px`,
          top: `${endTop}px`,
          transform: `perspective(1200px) scale(${gridScale})`,
        },
      ];

      detail!.removeAttribute("data-open");
      detail!.removeAttribute("data-is-you");
      detail!.setAttribute("aria-hidden", "true");

      const anim = o.clone.animate(keyframes, {
        duration: reduced ? 0 : isMobile ? 150 : 280,
        easing: "cubic-bezier(0.22, 1, 0.36, 1)",
        fill: "forwards",
      });
      anim.onfinish = () => {
        o.source.style.visibility = "";
        o.clone.remove();
      };
    };

    backdrop.addEventListener("click", closeDetail);
    closeBtn.addEventListener("click", closeDetail);

    const prevBtn = detail.querySelector<HTMLButtonElement>("[data-gallery-prev]");
    const nextBtn = detail.querySelector<HTMLButtonElement>("[data-gallery-next]");
    prevBtn?.addEventListener("click", () => navigateDetail(-1));
    nextBtn?.addEventListener("click", () => navigateDetail(1));

    /* ---------- report button ----------------------------------------- */
    const reportBtn = detail.querySelector<HTMLButtonElement>("[data-gallery-report]");
    const REPORT_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>`;
    function resetReportBtn() {
      if (!reportBtn) return;
      reportBtn.disabled = false;
      reportBtn.innerHTML = `${REPORT_SVG} Report`;
    }

    reportBtn?.addEventListener("click", async () => {
      if (!open) return;
      const cardId = open.source.dataset.id;
      if (!cardId) return;
      reportBtn.disabled = true;
      reportBtn.textContent = "Reporting\u2026";
      try {
        const res = await fetch("/api/report", {
          method: "POST",
          credentials: "same-origin",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ cardId }),
        });
        if (res.status === 401) {
          reportBtn.textContent = "Sign in to report";
        } else if (res.ok) {
          const data = await res.json();
          reportBtn.textContent = data.recorded ? "Reported" : "Already reported";
        } else {
          reportBtn.textContent = "Error";
        }
      } catch {
        reportBtn.textContent = "Error";
      }
      // Keep status visible; reset when user navigates or closes.
    });

    /* ---------- delete button ------------------------------------------ */
    const deleteBtn = detail.querySelector<HTMLButtonElement>("[data-gallery-delete]");
    const DELETE_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>`;
    let deleteConfirming = false;

    function resetDeleteBtn() {
      if (!deleteBtn) return;
      deleteConfirming = false;
      deleteBtn.disabled = false;
      deleteBtn.innerHTML = `${DELETE_SVG} Delete`;
      deleteBtn.classList.remove("!bg-red-100", "!text-red-600");
    }

    deleteBtn?.addEventListener("click", async () => {
      if (!open) return;
      if (!deleteConfirming) {
        deleteConfirming = true;
        deleteBtn.innerHTML = `${DELETE_SVG} Confirm delete?`;
        deleteBtn.classList.add("!bg-red-100", "!text-red-600");
        return;
      }
      deleteBtn.disabled = true;
      deleteBtn.textContent = "Deleting\u2026";
      try {
        const source = open!.source;
        const { deleteCard } = await import("../../lib/visitor");
        const ok = await deleteCard();
        if (ok) {
          if (open) closeDetail();
          source.remove();
          // Clear grid's youId so future detail opens don't show "you" actions.
          grid!.dataset.youId = "";
        } else {
          deleteBtn.textContent = "Error";
        }
      } catch {
        deleteBtn.textContent = "Error";
      }
    });

    window.addEventListener("keydown", (e) => {
      if (!open) return;
      if (e.key === "Escape") {
        closeDetail();
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        navigateDetail(1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        navigateDetail(-1);
      }
    });

    /* ---------- staggered FLIP shuffle -------------------------------- */

    /** Fisher-Yates, mutating a copy and returning it. */
    function fisherYates<T>(arr: T[]): T[] {
      const out = arr.slice();
      for (let i = out.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [out[i], out[j]] = [out[j], out[i]];
      }
      return out;
    }

    /** Weighted shuffle: 80% chance the current visitor lands in top-6. */
    function shuffleWithBias(cards: HTMLElement[]): HTMLElement[] {
      const shuffled = fisherYates(cards);
      const yid = getYouId();
      if (!yid) return shuffled;
      const youIdx = shuffled.findIndex((el) => el.dataset.id === yid);
      if (youIdx === -1) return shuffled;
      const topCap = Math.min(6, shuffled.length);
      if (Math.random() < 0.8) {
        const targetSlot = Math.floor(Math.random() * topCap);
        if (youIdx !== targetSlot) {
          const [mine] = shuffled.splice(youIdx, 1);
          shuffled.splice(targetSlot, 0, mine);
        }
      }
      return shuffled;
    }

    const runShuffle = () => {
      if (open) closeDetail();
      const cards = Array.from(grid!.children).filter(
        (n): n is HTMLElement => n instanceof HTMLElement,
      );
      if (cards.length < 2) return;

      // FIRST — capture original rects.
      const first = new Map<HTMLElement, DOMRect>();
      for (const c of cards) first.set(c, c.getBoundingClientRect());

      // Reorder DOM.
      const next = shuffleWithBias(cards);
      for (const c of next) grid!.appendChild(c);

      // LAST — rects after reflow.
      const last = new Map<HTMLElement, DOMRect>();
      for (const c of next) last.set(c, c.getBoundingClientRect());

      // INVERT + PLAY with stagger.
      next.forEach((c, i) => {
        const f = first.get(c)!;
        const l = last.get(c)!;
        const dx = f.left - l.left;
        const dy = f.top - l.top;
        if (dx === 0 && dy === 0) return;
        c.dataset.flying = "";
        const anim = c.animate(
          [
            { transform: `translate(${dx}px, ${dy}px)` },
            { transform: `translate(0, 0)` },
          ],
          {
            duration: reduced ? 0 : isMobile ? 300 : 560,
            delay: reduced ? 0 : isMobile ? i * 10 : i * 20,
            easing: SPRING_EASE,
            fill: "both",
          },
        );
        anim.onfinish = () => {
          // Clear the fill so the hover handler's inline transform isn't
          // masked by the animation's retained endpoint (WAAPI animations
          // override inline styles unless the effect is cancelled).
          try {
            anim.cancel();
          } catch {}
          delete c.dataset.flying;
          c.style.transform = "";
        };
      });
    };

    window.addEventListener("gallery:shuffle", runShuffle);

    /* ---------- wiring (delegated — no per-card setup needed) ---------- */

    // If the detail is resized (e.g. viewport change), reposition.
    window.addEventListener("resize", () => {
      if (!open) return;
      const W = parseFloat(open.clone.style.width);
      const H = parseFloat(open.clone.style.height);
      const target = computeTarget(open.startRect);
      open.scale = target.scale;
      open.targetRect = {
        left: window.innerWidth / 2 - W / 2,
        top: window.innerHeight / 2 - H / 2,
        width: W * target.scale,
        height: H * target.scale,
      };
      open.clone.style.left = `${window.innerWidth / 2 - W / 2}px`;
      open.clone.style.top = `${window.innerHeight / 2 - H / 2}px`;
      open.clone.style.transform = `perspective(1200px) scale(${target.scale})`;
    });

    /* ---------- lazy-load signatures for visible mini cards ---------- */
    const sigObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const wrap = entry.target as HTMLElement;
          sigObserver.unobserve(wrap);
          const cardId = wrap.dataset.id;
          if (cardId) lazyLoadSignature(wrap, cardId);
        }
      },
      { rootMargin: "200px 0px" },
    );

    function observeMiniCards() {
      grid!.querySelectorAll<HTMLElement>(
        "[data-mini-card-wrap]:not([data-sig-queued])",
      ).forEach((wrap) => {
        wrap.dataset.sigQueued = "";
        sigObserver.observe(wrap);
      });
    }
    observeMiniCards();

    /* ---------- "Load more" pagination ------------------------------- */
    const loadMoreBtn = document.querySelector<HTMLButtonElement>("[data-gallery-load-more]");
    if (loadMoreBtn) {
      let loading = false;

      loadMoreBtn.addEventListener("click", async () => {
        if (loading) return;
        loading = true;
        loadMoreBtn.textContent = "Loading\u2026";

        const offset = Number(grid.dataset.offset ?? 0);
        const pageSize = Number(grid.dataset.pageSize ?? 48);
        const totalReal = Number(grid.dataset.totalReal ?? 0);
        // Read youId fresh — client-side fallback may have set it after wiring.
        const currentYouId = grid.dataset.youId || null;
        const params = new URLSearchParams({
          offset: String(offset),
          limit: String(pageSize),
          ...(currentYouId ? { youId: currentYouId } : {}),
        });

        try {
          const res = await fetch(`/api/gallery-cards?${params}`);
          if (!res.ok) throw new Error("fetch failed");
          const html = await res.text();

          // Parse new cards, skip any that are already in the grid (e.g. the
          // current visitor's card was injected into the initial batch).
          const frag = document.createRange().createContextualFragment(html);
          const existingIds = new Set(
            Array.from(grid.querySelectorAll<HTMLElement>("[data-mini-card-wrap]"))
              .map((el) => el.dataset.id),
          );
          for (const node of Array.from(frag.querySelectorAll<HTMLElement>("[data-mini-card-wrap]"))) {
            if (node.dataset.id && existingIds.has(node.dataset.id)) {
              node.remove();
            }
          }
          grid.appendChild(frag);

          // Observe new cards for lazy signature loading.
          observeMiniCards();

          // Update offset for next page.
          const newOffset = offset + pageSize;
          grid.dataset.offset = String(newOffset);

          // Invalidate pet ledge cache so new cards are discoverable.
          window.dispatchEvent(new CustomEvent("gallery:cards-added"));

          // Hide button if all cards loaded.
          if (newOffset >= totalReal) {
            loadMoreBtn.remove();
          }
        } catch {
          // Silently fail — button stays for retry.
        } finally {
          loading = false;
          if (loadMoreBtn.parentElement) {
            loadMoreBtn.innerHTML = `Load more <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>`;
          }
        }
      });
    }
  }
  }
  wireGallery();
  document.addEventListener("astro:page-load", wireGallery);
</script>
