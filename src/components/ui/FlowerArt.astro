  "в Җв Җв Җв Җв Җв Җв үв үв үв үв Җв Җв ҖвўӨвЎјв үвў№вЎЈвЈүв ҖвЈҝвЈҝвЎҮв Җв Җвў вЈҙв ¶вўҰвЎҖв Җв Ғв Җв ҖвЈҷвЎӮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ",
];

const ORANGE_ART: string[] = [
  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЈӨвЈҙвЈҰвЈҰвЎ„в Җв Җв Җв Җ",
  "в Җв Җв ҖвЈҖвЈӨвЈӨвЈӨвЈӨвЈҖвЈҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈӨвЈ¶вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈ„в Җв Җ",
  "в ҖвЈ°вЈҝвЈҝв ҝвўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈҰвЈҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ вЈҫвЈҝвЈҝвЈҝв ҝв ӣв үв үв Ғв үв үв ҷв »вЈ§в Җ",
  "вЈ°вЈҝвЈҝвЎҹв Җв Җв Ҳв ҷв ӣв ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ¶вЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҙвЈҝвЈҝвЎҝв ҹв Ӣв Ғв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўёвЎҶ",
  "вЈҝвЈҝвЈҝв Ғв Җв Җв Җв Җв Җв Җв Җв Ҳв ҷв ӣв ҝвўҝвЈҝвЈҝвЈҰвЈҖв Җв Җв Җв Җв Җв ҖвўҖвЈҙвЈҝвЎҝв ӣв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҪвЈ§",
  "вЈҝвЈҝвЈҝв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвўҖв Ҳв ҷв »вЈҝвЈ·вЈ„вЈӨвЈӨвЈӨвЈҰвЈҫвЎҝв Ӣв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈјвЈҝвЎҝ",
  "вЈҝвЈҝвЈҝвЈ·вЈ„вЈҖвЈҖвЈҖвЈҖвЈ вЈӨвЈ¶вЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ¶вЈ¶вЈҝвЈ¶вЈ¶вЈӨвЈҖв Җв ҖвўҖв Җв Җв Җв ҖвЈҖвЈ вЈҫвЈҝвЈҝв ғ",
  "в ҳвўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв ӣв Ӣв үв үвЈҙвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҜвЈҚв үв ӣв »вўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв ҝв ғв Җ",
  "в Җв Җв үв ӣв »в ҝв ҝв ҝв ҝв ҝв ҝв ӣв Ӣв Җв Җв Җв Җвў вЈҫвЈҝвЈҝв ҹв Ғв Ғв Җв Ҳв »вЈҝвЈҝвЈ·вЎҖв Җв Җв үв ӣв »в ҝв ҝв »в ҝв ҝв ҹв Ӣв Ғв Җв Җв Җ",
  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЈҝвЈҝвЈҝв ғв Җв Җв Җв Җв Җв Җв №вЈҝвЈҝвЈ§в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ",
  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҫвЈҝвЈҝвЎҸв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЈҝвЈҝвЎҶв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ",
  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈ вЈҝвЈҝвЈҝвЎҹв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўёвЈҝвЈҝвЈ·в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ",
  "в Җв Җв Җв Җв Җв ҖвЈҖвЈ вЈӨвЈҙвЈ¶вЈ¶вЈҫвЈҝвЈҝвЈҝвЈҝв ҹв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳвЈҝвЈҝвЈҝвЈ§вЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ",
  "в Җв Җв ҖвЈ вЈҙвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв ҝв ҹв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳвЈҝвЈҝвЈҝвЈҝвЈ·вЈҰвЈӨвЈҖвЎҖв Җв Җв Җв Җв Җв Җв Җв Җ",
  "в Җв ҖвЈҙвЈҝвЈҝвЈҝв ҹв үв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ӣвўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈӨвЎҖв Җв Җв Җв Җв Җ",
];

type ArtConfig = {
  lines: string[];
  fontSize: string;
  lineHeight: string;
  glimmerCount: number;
  seed: number;
};

const ARTS: Record<CardColor, ArtConfig> = {
  pink:    { lines: BUTTERFLIES, fontSize: "15px", lineHeight: "1.08", glimmerCount: 14, seed: 0xa1b2 },
  neutral: { lines: BUTTERFLIES, fontSize: "15px", lineHeight: "1.08", glimmerCount: 14, seed: 0x4242 },
  teal:    { lines: TEAL_ART,    fontSize: "15px", lineHeight: "1.08", glimmerCount: 12, seed: 0x7e4c },
  green:   { lines: GREEN_ART,   fontSize: "7.5px", lineHeight: "1.1", glimmerCount: 20, seed: 0x0f1b },
  orange:  { lines: ORANGE_ART,  fontSize: "9px",  lineHeight: "1.08", glimmerCount: 16, seed: 0xfc03 },
};

function mulberry32(a: number) {
  return function () {
    a = (a + 0x6d2b79f5) | 0;
    let t = a;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

function pickGlimmers(lines: string[], count: number, seed: number) {
  const rng = mulberry32(seed);
  const positions: Array<{ row: number; col: number }> = [];
  for (let r = 0; r < lines.length; r++) {
    const chars = Array.from(lines[r]);
    for (let c = 0; c < chars.length; c++) {
      const ch = chars[c];
      if (ch !== "в Җ" && ch !== " " && ch !== "") positions.push({ row: r, col: c });
    }
  }
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [positions[i], positions[j]] = [positions[j], positions[i]];
  }
  return positions.slice(0, count).map((p) => ({
    row: p.row,
    col: p.col,
    delay: Number((rng() * 3.6).toFixed(2)),
    duration: Number((2.2 + rng() * 1.6).toFixed(2)),
  }));
}

const cfg = ARTS[color];
const glimmers = pickGlimmers(cfg.lines, cfg.glimmerCount, cfg.seed);
const glimmerMap = new Map<string, { delay: number; duration: number }>();
for (const g of glimmers) glimmerMap.set(`${g.row}:${g.col}`, { delay: g.delay, duration: g.duration });

const html = cfg.lines
  .map((line, r) => {
    const chars = Array.from(line);
    return chars
      .map((ch, c) => {
        const g = glimmerMap.get(`${r}:${c}`);
        if (g) {
          return `<span class="glimmer" style="--glimmer-delay:${g.delay}s;--glimmer-duration:${g.duration}s">${ch}</span>`;
        }
        return ch;
      })
      .join("");
  })
  .join("\n");

const baseStyle = `font-size:${cfg.fontSize};line-height:${cfg.lineHeight};transform:scale(${scale});transform-origin:top right;${opacity !== undefined ? `opacity:${opacity};` : ""}${styleOverride}`;
---

<pre
  aria-hidden="true"
  data-flower-art={color}
  class={`flower-art pointer-events-none whitespace-pre font-[family-name:var(--font-mono)] ${className}`}
  style={baseStyle}
  set:html={html}
/>

<style is:global>
  /* Per-color palette. Matches the library card so the footer/card look like
     the same illustration. */
  .flower-art[data-flower-art="pink"] {
    color: var(--color-pink-0);
    --flower-peak: #ffffff;
    --flower-halo: rgba(255, 255, 255, 0.85);
  }
  .flower-art[data-flower-art="teal"] {
    color: var(--color-teal-3);
    --flower-peak: #d9ebee;
    --flower-halo: rgba(217, 235, 238, 0.6);
  }
  .flower-art[data-flower-art="green"] {
    color: var(--color-green-1);
    --flower-peak: #ffffff;
    --flower-halo: rgba(255, 255, 255, 0.85);
  }
  .flower-art[data-flower-art="orange"] {
    color: var(--color-orange-1);
    --flower-peak: #ffffff;
    --flower-halo: rgba(255, 255, 255, 0.85);
  }
  .flower-art[data-flower-art="neutral"] {
    color: var(--color-fg-neutral);
    --flower-peak: var(--color-ink);
    --flower-halo: rgba(36, 36, 36, 0.5);
  }

  .flower-art .glimmer {
    display: inline-block;
    color: var(--flower-peak);
    animation: flower-art-glimmer var(--glimmer-duration, 2.8s) ease-in-out var(--glimmer-delay, 0s) infinite;
    will-change: opacity;
  }

  @keyframes flower-art-glimmer {
    0%, 100% {
      opacity: 0.2;
      text-shadow: 0 0 0 transparent;
    }
    35% {
      opacity: 1;
      text-shadow: 0 0 4px var(--flower-halo, rgba(255, 255, 255, 0.85));
    }
    60% {
      opacity: 0.1;
      text-shadow: 0 0 0 transparent;
    }
    82% {
      opacity: 1;
      text-shadow: 0 0 3px var(--flower-halo, rgba(255, 255, 255, 0.85));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flower-art .glimmer {
      animation: none;
      opacity: 0.7;
    }
  }
</style>
