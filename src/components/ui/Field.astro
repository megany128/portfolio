---
interface Props {
  name: string;
  label: string;
  type?: "text" | "email" | "url";
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  multiline?: boolean;
  rows?: number;
}

const {
  name,
  label,
  type = "text",
  placeholder,
  required = false,
  autocomplete,
  multiline = false,
  rows = 4,
} = Astro.props;

const inputCls =
  "w-full bg-transparent text-[var(--color-ink)] placeholder:text-[var(--color-ink-mute)] border-b border-[var(--color-bg-neutral-2)] focus:border-[var(--color-ink)] outline-none py-2 text-base transition-colors duration-[var(--duration-fast)]";
---

<label class="flex flex-col gap-1.5">
  <span class="font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.12em] text-[var(--color-ink-mute)]">
    {label}{required && <span aria-hidden="true"> *</span>}
  </span>
  {
    multiline ? (
      <textarea
        name={name}
        rows={rows}
        placeholder={placeholder}
        required={required}
        class={inputCls}
      />
    ) : (
      <input
        name={name}
        type={type}
        placeholder={placeholder}
        required={required}
        autocomplete={autocomplete}
        class={inputCls}
      />
    )
  }
</label>
