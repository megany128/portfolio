---
// Three corner sparkles, positioned per Figma frame (1280×832 base).
// Kept purely decorative — no parallax — so they feel painted on the sky
// rather than floating free.
---

<div
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 overflow-hidden text-2xl text-[#aba695] font-[family-name:var(--font-mono)]"
>
  <span class="absolute" style="left:12.5%; top:48.9%;">
    <span class="text-[var(--color-pink)]">⊹</span> ࣪ ˖
  </span>
  <span class="absolute" style="left:73.3%; top:82.1%;">
    ⋆.<span class="text-[var(--color-teal)]">˚</span>
  </span>
  <span class="absolute" style="left:84.4%; top:24.3%;">
    ˚<span class="text-[var(--color-orange)]">.</span>⋆
  </span>
</div>
