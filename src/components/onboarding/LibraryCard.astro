  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ёвЈҝв Ҹв Җв Җ",
  "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв  в ҹв Җв Җв Җ",
];

const ARTS: Record<CardColor, ArtConfig> = {
  pink: {
    lines: BUTTERFLIES,
    fontSize: "15px",
    lineHeight: "1.08",
    right: "-32px",
    bottom: "-18px",
    glimmerCount: 14,
    seed: 0xa1b2,
  },
  neutral: {
    lines: BUTTERFLIES,
    fontSize: "15px",
    lineHeight: "1.08",
    right: "-32px",
    bottom: "-18px",
    glimmerCount: 14,
    seed: 0x4242,
  },
  teal: {
    lines: TEAL_ART,
    fontSize: "15px",
    lineHeight: "1.08",
    right: "-10px",
    bottom: "-8px",
    glimmerCount: 12,
    seed: 0x7e4c,
  },
  green: {
    lines: GREEN_ART,
    fontSize: "7.5px",
    lineHeight: "1.1",
    right: "-6px",
    bottom: "-16px",
    glimmerCount: 20,
    seed: 0x0f1b,
  },
  orange: {
    lines: ORANGE_ART,
    fontSize: "9px",
    lineHeight: "1.08",
    right: "-8px",
    bottom: "-6px",
    glimmerCount: 16,
    seed: 0xfc03,
  },
};

// Simple deterministic PRNG so each build picks the same glimmer dots.
function mulberry32(a: number) {
  return function () {
    a = (a + 0x6d2b79f5) | 0;
    let t = a;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

function pickGlimmers(lines: string[], count: number, seed: number) {
  const rng = mulberry32(seed);
  const positions: Array<{ row: number; col: number }> = [];
  for (let r = 0; r < lines.length; r++) {
    const chars = Array.from(lines[r]);
    for (let c = 0; c < chars.length; c++) {
      const ch = chars[c];
      if (ch !== "в Җ" && ch !== " " && ch !== "") positions.push({ row: r, col: c });
    }
  }
  // Shuffle, take first N.
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [positions[i], positions[j]] = [positions[j], positions[i]];
  }
  return positions.slice(0, count).map((p) => ({
    row: p.row,
    col: p.col,
    delay: Number((rng() * 3.6).toFixed(2)),
    duration: Number((2.2 + rng() * 1.6).toFixed(2)),
  }));
}

function renderArt(cfg: ArtConfig) {
  const glimmers = pickGlimmers(cfg.lines, cfg.glimmerCount, cfg.seed);
  const glimmerMap = new Map<string, { delay: number; duration: number }>();
  for (const g of glimmers) glimmerMap.set(`${g.row}:${g.col}`, { delay: g.delay, duration: g.duration });

  const html = cfg.lines
    .map((line, r) => {
      const chars = Array.from(line);
      return chars
        .map((ch, c) => {
          const g = glimmerMap.get(`${r}:${c}`);
          if (g) {
            return `<span class="glimmer" style="--glimmer-delay:${g.delay}s;--glimmer-duration:${g.duration}s">${ch}</span>`;
          }
          return ch;
        })
        .join("");
    })
    .join("\n");

  const style = `font-size:${cfg.fontSize};line-height:${cfg.lineHeight};right:${cfg.right};bottom:${cfg.bottom};`;
  return { html, style };
}

// Render every art once; CSS reveals only the one matching `data-color` so
// the silhouette swaps along with the card's color via the ripple transition.
const rendered = (Object.entries(ARTS) as Array<[CardColor, ArtConfig]>).map(
  ([key, cfg]) => ({
    key,
    ...renderArt({ ...cfg, seed: (cfg.seed ^ (glimmerSeedSalt | 0)) >>> 0 }),
  })
);

/*
  Artistic fallback signature for visitors who didn't draw one. We pick a
  variant deterministically from the visitor name + number so the same card
  always renders the same doodle. SVGs are hand-tuned to land above the
  `x ______` baseline, centered in the card's lower half.
*/
function hashString(s: string): number {
  let h = 0x811c9dc5;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 0x01000193);
  }
  return h >>> 0;
}

const FALLBACK_VARIANTS = ["smiley", "scribble", "heart", "initial", "star"] as const;
type FallbackVariant = (typeof FALLBACK_VARIANTS)[number];
const fallbackVariant: FallbackVariant =
  FALLBACK_VARIANTS[hashString(`${name}:${number}`) % FALLBACK_VARIANTS.length];

const firstLetter = (name.trim()[0] ?? "?").toUpperCase();
const showFallback = !signable && !signature;
---

<article
  id={id}
  data-color={color}
  data-name={name}
  class="library-card relative w-[388px] h-[252px] rounded-[24px] overflow-hidden p-7 flex flex-col text-[var(--color-ink-inverted)] font-[family-name:var(--font-mono)] uppercase select-none"
>
  <!-- Decorative braille-dot illustration вҖ” one <pre> per color; CSS reveals
       only the one whose data-for matches the card's current data-color. -->
  {rendered.map((r) => (
    <pre
      aria-hidden="true"
      data-for={r.key}
      class="library-card__flower absolute pointer-events-none whitespace-pre"
      style={r.style}
      set:html={r.html}
    />
  ))}

  <h2
    class="font-[family-name:var(--font-display)] font-light text-[24px] leading-none normal-case relative"
  >
    Megan&rsquo;s World
  </h2>

  <dl class="mt-6 flex flex-col gap-2 relative">
    <div class="flex flex-col">
      <dt class="text-[14px] leading-none text-[var(--card-tint)]">Visitor</dt>
      <dd class="text-[18px] leading-none mt-1.5" data-card-name>{name}</dd>
    </div>
    <div class="flex flex-col mt-2">
      <dt class="text-[14px] leading-none text-[var(--card-tint)]">Issued on</dt>
      <dd class="text-[18px] leading-none mt-1.5" data-card-date>{formatted}</dd>
    </div>
  </dl>

  <div class="mt-auto flex items-end justify-between relative">
    <p class="text-[14px] leading-none text-[var(--card-tint)]" data-card-number>
      No. {number}
    </p>
    <div class="flex items-end gap-2 grow ml-12">
      <span class="text-[18px] leading-none">x</span>
      <span class="block flex-1 border-b border-[var(--color-ink-inverted)] mb-1"></span>
    </div>
  </div>

  {signable && <SignaturePad />}

  {!signable && signature && (
    <img
      src={signature}
      alt="signature"
      class="library-card__signature absolute inset-0 w-full h-full object-contain pointer-events-none"
      loading="lazy"
      decoding="async"
    />
  )}

  {showFallback && (
    <svg
      aria-hidden="true"
      class="library-card__fallback-sig pointer-events-none"
      viewBox="0 0 180 60"
      preserveAspectRatio="xMidYMid meet"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      {fallbackVariant === "smiley" && (
        <g>
          <circle cx="90" cy="30" r="18" />
          <circle cx="83" cy="26" r="1.6" fill="currentColor" stroke="none" />
          <circle cx="97" cy="26" r="1.6" fill="currentColor" stroke="none" />
          <path d="M80 34 Q90 44 100 34" />
          <path d="M118 20 q3 -4 6 0 q3 4 6 0" opacity="0.7" />
          <path d="M52 42 q3 -4 6 0 q3 4 6 0" opacity="0.7" />
        </g>
      )}
      {fallbackVariant === "scribble" && (
        <path d="M20 36 Q28 18 38 34 T58 32 Q68 14 76 34 T98 30 Q108 12 118 34 T140 30 Q150 16 160 34" />
      )}
      {fallbackVariant === "heart" && (
        <g>
          <path d="M70 28 q-10 -14 -22 -2 q-12 12 22 30 q34 -18 22 -30 q-12 -12 -22 2 z" />
          <path d="M102 18 l42 0 M102 30 l54 0 M102 42 l36 0" opacity="0.55" />
        </g>
      )}
      {fallbackVariant === "initial" && (
        <g>
          <text
            x="40"
            y="44"
            font-family="var(--font-display)"
            font-size="44"
            font-style="italic"
            font-weight="300"
            fill="currentColor"
            stroke="none"
          >{firstLetter}</text>
          <path d="M74 44 Q98 14 126 40 T170 36" opacity="0.85" />
        </g>
      )}
      {fallbackVariant === "star" && (
        <g>
          <path d="M30 36 Q50 14 72 36 Q92 58 116 36 Q136 14 160 36" />
          <path d="M40 46 l4 -4 M148 20 l4 -4" opacity="0.65" />
          <path d="M92 8 l2 6 M96 8 l-2 6" opacity="0.7" />
        </g>
      )}
    </svg>
  )}
</article>

<style is:global>
  /*
    Smooth color + tint transitions so when the card's data-color attribute
    swaps, labels and the flower colorize alongside the ripple wash instead
    of snapping.
  */
  .library-card,
  .library-card .library-card__flower,
  .library-card dt,
  .library-card dd,
  .library-card p,
  .library-card span {
    transition: color 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                background-color 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .library-card[data-color="pink"] {
    background: var(--color-pink);
    --card-tint: var(--color-pink-1);
    --card-tint-soft: var(--color-pink-2);
    --card-flower-base: var(--color-pink-0);
    --card-flower-peak: #ffffff;
  }
  .library-card[data-color="teal"] {
    background: var(--color-teal);
    --card-tint: var(--color-teal-1);
    --card-tint-soft: var(--color-teal-3);
    --card-flower-base: var(--color-teal-3);
    /* Muted aqua-white so the glimmer sparkles without looking like
       hot-white pinpricks against the cooler teal card. */
    --card-flower-peak: #d9ebee;
    --card-flower-halo: rgba(217, 235, 238, 0.6);
  }
  .library-card[data-color="green"] {
    background: var(--color-green);
    --card-tint: var(--color-green-1);
    --card-tint-soft: var(--color-green-2);
    --card-flower-base: var(--color-green-1);
    --card-flower-peak: #ffffff;
  }
  .library-card[data-color="orange"] {
    background: var(--color-orange);
    --card-tint: var(--color-orange-1);
    --card-tint-soft: var(--color-orange-2);
    --card-flower-base: var(--color-orange-1);
    --card-flower-peak: #ffffff;
  }
  .library-card[data-color="neutral"] {
    background: var(--color-bg-neutral-2);
    color: var(--color-ink);
    --card-tint: var(--color-fg-neutral);
    --card-tint-soft: var(--color-bg-neutral);
    --card-flower-base: var(--color-fg-neutral);
    --card-flower-peak: var(--color-ink);
  }
  .library-card[data-color="neutral"] .border-\[var\(--color-ink-inverted\)\] {
    border-color: var(--color-ink);
  }

  /* The illustration sits on the right side of the card with the base in a
     lighter shade of the card tone; individual dots can flash via .glimmer. */
  .library-card__flower {
    color: var(--card-flower-base);
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Reveal the art that matches the card's current color. */
  .library-card[data-color="pink"] .library-card__flower[data-for="pink"],
  .library-card[data-color="teal"] .library-card__flower[data-for="teal"],
  .library-card[data-color="green"] .library-card__flower[data-for="green"],
  .library-card[data-color="orange"] .library-card__flower[data-for="orange"],
  .library-card[data-color="neutral"] .library-card__flower[data-for="neutral"] {
    opacity: 0.82;
  }
  /* Static signature overlay in gallery view вҖ” drawn in the same pen color
     the visitor used in onboarding, with no blend mode so it matches the
     onboarding canvas (which is a plain RGB overlay on the card). */
  .library-card__signature {
    mix-blend-mode: normal;
  }

  /* Fallback artistic signature вҖ” positioned above the `x ______` baseline,
     tinted with each card's soft peak color so it feels like ink, not print. */
  .library-card__fallback-sig {
    position: absolute;
    left: 50%;
    bottom: 34px;
    width: 160px;
    height: 56px;
    transform: translateX(-44%) rotate(-3deg);
    color: var(--card-flower-peak, var(--color-ink-inverted));
    opacity: 0.92;
  }
  .library-card[data-color="neutral"] .library-card__fallback-sig {
    color: var(--color-ink);
    opacity: 0.82;
  }

  .library-card__flower .glimmer {
    display: inline-block;
    color: var(--card-flower-peak);
    animation: flower-glimmer var(--glimmer-duration, 2.8s) ease-in-out var(--glimmer-delay, 0s) infinite;
    will-change: opacity;
  }

  /* Glimmer dots flash noticeably against the base-tint silhouette вҖ” they
     brighten past the parent opacity via their own text-shadow halo when
     near-peak, so the flash reads clearly even on busy areas of the art.
     Each card color can override --card-flower-halo to soften the bloom. */
  @keyframes flower-glimmer {
    0%, 100% {
      opacity: 0.2;
      text-shadow: 0 0 0 transparent;
    }
    35% {
      opacity: 1;
      text-shadow: 0 0 4px var(--card-flower-halo, rgba(255, 255, 255, 0.85));
    }
    60% {
      opacity: 0.1;
      text-shadow: 0 0 0 transparent;
    }
    82% {
      opacity: 1;
      text-shadow: 0 0 3px var(--card-flower-halo, rgba(255, 255, 255, 0.85));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .library-card__flower .glimmer {
      animation: none;
    }
  }
</style>
