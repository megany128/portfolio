---
// Submission animation overlay (Figma 7:347).
// Hidden until VisitorCard dispatches `wallet:play`. Then:
//   1. Snapshot the hero signature canvas BEFORE the page changes.
//   2. Fetch a few other visitors' cards.
//   3. Slide them into a horizontal row from the right.
//   4. The user's card drops from above and snaps into the row.
//   5. The whole row whooshes off to the left.
//   6. Navigate to /home.
//
// Mini-card visuals mirror LibraryCard: same dimensions, same per-color art,
// same glimmer shader. We reuse the `.library-card` class so the global CSS
// from LibraryCard (backgrounds, tints, flower opacity, @keyframes
// flower-glimmer) applies without duplication. `.wallet-mini` only owns
// animation-specific positioning/shadow concerns.
---

<div
  data-wallet-overlay
  aria-hidden="true"
  class="fixed inset-0 z-50 grid place-items-center pointer-events-none opacity-0"
>
  <!-- Cream backdrop matching the spotlight, fades in to cover the form.
       Shares `transition:name="wallet-veil"` with a matching cream veil on
       /home so the cream persists seamlessly across the navigation and
       then peels back to reveal the home content. -->
  <div
    data-wallet-bg
    transition:name="wallet-veil"
    class="absolute inset-0 bg-[var(--color-bg)] opacity-0"
  ></div>

  <!-- Card track. Cards are absolutely positioned within so we have full GSAP control. -->
  <div
    data-wallet-track
    class="relative w-full h-[252px] overflow-visible flex items-center justify-center"
  ></div>
</div>

<style is:global>
  /*
    `.wallet-mini` layers animation concerns on top of `.library-card`:
    centered absolute positioning (GSAP x/y becomes an offset from center)
    and a soft lift shadow. Everything visual вҖ” background color, tint vars,
    braille art, glimmers, typography вҖ” comes from `.library-card`.
  */
  .wallet-mini {
    position: absolute;
    left: 50%;
    top: 50%;
    margin-left: -194px;  /* -cardW / 2 */
    margin-top: -126px;   /* -cardH / 2 */
    will-change: transform, opacity;
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, 0.25);
  }

  /* Signature image rendered inside a wallet hero card. Sits in the same
     inset as the live SignaturePad canvas so the ink lands in the exact
     spot the user drew it. */
  .wallet-mini .wallet-signature {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    user-select: none;
  }
</style>

