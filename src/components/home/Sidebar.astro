---
import Logo from "../ui/Logo.astro";
import TableOfContents from "./TableOfContents.astro";
import type { CardColor } from "../../lib/visitor";

interface Props {
  active?: "work" | "about" | "playground" | "gallery";
  anon?: boolean;
  visitorCard?: { name: string; color: CardColor; number: number; signature?: string | null } | null;
}

const { active = "work", anon = false, visitorCard = null } = Astro.props;
---

<!-- Tab that sticks out on the left edge when the sidebar is collapsed -->
<button
  type="button"
  data-sidebar-toggle
  aria-label="Open sidebar"
  aria-controls="site-sidebar"
  aria-expanded="false"
  class="sidebar-tab"
>
  <span class="sidebar-tab-dots" aria-hidden="true">
    <span></span><span></span><span></span>
  </span>
  <span class="sidebar-tab-arrow" aria-hidden="true">вҖә</span>
</button>

<!-- Backdrop closes the sidebar on small screens -->
<div data-sidebar-backdrop class="sidebar-backdrop" aria-hidden="true"></div>

<aside
  id="site-sidebar"
  data-sidebar
  transition:name="sidebar"
  transition:animate="none"
  class="site-sidebar bg-[var(--color-bg-light)] flex flex-col gap-6 p-10 w-[303px] flex-shrink-0"
>
  <button
    type="button"
    data-sidebar-close
    aria-label="Close sidebar"
    class="sidebar-close"
  >
    <span aria-hidden="true">Г—</span>
  </button>

  <div class="flex flex-col gap-2">
    <a
      href="/home"
      aria-label="Home"
      data-logo-link
      class="sidebar-logo-link inline-block w-fit transition-transform hover:scale-[1.08] active:scale-[1.18] relative"
    >
      <span data-logo-spin class="sidebar-logo-spin inline-block">
        <Logo class="mb-1" />
      </span>
      <span data-logo-sparks aria-hidden="true" class="sidebar-logo-sparks pointer-events-none absolute inset-0"></span>
    </a>
    <h1 class="font-[family-name:var(--font-display)] font-light text-[36px] leading-none text-[var(--color-ink)]">
      Megan Yap
    </h1>
    <p class="font-[family-name:var(--font-mono)] text-base uppercase text-[var(--color-ink-dim)] leading-snug">
      CS &amp; Linguistics @ Cornell
    </p>
    <p class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug">
      I am a dreamer who loves building delightful software that solves real problems.
    </p>
    <p class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug">
      Incoming <span class="text-[var(--color-ink)]">@Google</span>, previously at <span class="text-[var(--color-ink)]">@Splunk</span>, <span class="text-[var(--color-ink)]">@RxPost</span>, and <span class="text-[var(--color-ink)]">@Clear</span> (YC W21).
    </p>
  </div>

  <TableOfContents active={active} anon={anon} />

  <div class="flex flex-col gap-0.5">
    <p class="font-[family-name:var(--font-mono)] text-base uppercase text-[var(--color-ink)]">
      Find me at
    </p>
    <p class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)]">
      <a href="mailto:may52@cornell.edu" class="text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] underline-offset-4 hover:underline">Email</a>,
      <a href="https://www.linkedin.com/in/megan-qz-yap/" class="text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] underline-offset-4 hover:underline">LinkedIn</a>,
      <a href="https://github.com/megany128" class="text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] underline-offset-4 hover:underline">GitHub</a>,
      <a href="https://x.com/maqzyap" class="text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] underline-offset-4 hover:underline">X</a>
    </p>
  </div>

  {visitorCard && (
    <div class="sidebar-visitor-card-wrap" data-color={visitorCard.color}>
      <a
        href="/visitor-gallery"
        data-sidebar-card
        data-cursor-bg={visitorCard.color}
        class="sidebar-card-pill"
        aria-label="Your visitor card вҖ” view gallery"
      >
        <span class="sidebar-card-pill__dot"></span>
        <span class="sidebar-card-pill__label">My visitor card</span>
      </a>
      <div class="sidebar-card-popover">
        <a href="/visitor-gallery" class="sidebar-card-popover__link" data-cursor-bg={visitorCard.color}>
          <pre class="sidebar-card__art" aria-hidden="true">{
            visitorCard.color === "teal"
              ? "в Җв Җв ҖвўёвЈҰвЎҖв Җв Җв Җв ҖвўҖвЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв ҖвўёвЈҸв »вЈ¶вЈӨвЎ¶вўҫвЎҝв Ғв Җвў вЈ„вЎҖвўҖвЈҙв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв ҖвЈҖвЈјв ·в Җв Җв ҒвўҖвЈҝв ғв Җв ҖвўҖвЈҝвЈҝвЈҝвЈҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв ҙвЈҫвЈҜвЈ…вЈҖв Җв Җв Җв Ҳвў»вЈҰвЎҖв ’в »в ҝвЈҝвЎҝв ҝв “в Ӯв Җв ҖвўҖвЎҮв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв үвў»вЎҮвЈӨвЈҫвЈҝвЈ·вЈҝвЈҝвЈӨв Җв ҖвЈҝв Ғв Җв Җв ҖвўҖвЈҙвЈҝвЈҝв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв ёвЈҝвЎҝв Ҹв ҖвўҖв Җв Җв ҝвЈ¶вЈӨвЈӨвЈӨвЈ„вЈҖвЈҙвЈҝвЎҝвў»вЈҝвЎҶв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв ҹв Ғв ҖвўҖвЈјв Җв Җв Җв №вЈҝвЈҹв ҝв ҝв ҝвЎҝв Ӣв Җв ҳвЈҝвЈҮв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв ҖвўівЈ¶вЈ¶вЈҝвЈҝвЈҮвЈҖв Җв Җв ҷвЈҝвЈҶв Җв Җв Җв Җв Җв Җв ӣв ҝвЈҝвЈҰвЈӨвЈҖв Җв Җ\nв Җв Җв Җв Җв Җв ҖвЈ№вЈҝвЈҝвЈҝвЈҝв ҝв Ӣв Ғв ҖвЈ№вЈҝв ів Җв Җв Җв Җв Җв ҖвўҖвЈ вЈҪвЈҝвЎҝв ҹв ғ\nв Җв Җв Җв Җв Җвў°в ҝв ӣв »вўҝвЎҮв Җв Җв ҖвЈ°вЈҝв Ҹв Җв ҖвўҖв Җв Җв ҖвЈҫвЈҝв ҹв Ӣв Ғв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ӣв Җв ҖвЈ°вЈҝвЈҝвЈҫвЈҝв ҝвўҝвЈ·вЈҖвўҖвЈҝвЎҮв Ғв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ӣв үв Ғв Җв Җв Җв Җв ҷвўҝвЈҝвЈҝв Үв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷвўҝв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв Җв Җв Җв Җв Җв Җв Җ"
              : visitorCard.color === "green"
                ? "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ вўҫвЈӣвЎҶв ҲвЎҸв °в ¶в ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҰвЈҝвЈ„вЈүвЈҒвЈӨв ҪвЈҰвЈӨвЎ¶в ¶вЈӨвЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв үв ҡв №вЎүвўғвЈҙв ҹв үв Җв Җв Җв Җв үв »вЈҰвЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈӨвўЎвЎҝв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Ҳвў·вЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎӮвЈҝвЎҮв Җв Җв Җв ҖвЈ вЈӨвЈҖв Җв Җв Җв ҳвЈҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ғвў»вЈ·в Җв Җв Җв ҖвўҜвЎүвЈҝвЎҶв Җв ҖвЈ°вЎҮв ҖвўҖвЈҖвўӨв Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳвўҝвЈ§вЈҖв Җв ҖвўҖвЈҙвЎҹв Җв ҖвЈ°вЈҝвЎ·вўҸвЎӯв ”в №в Җв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷв ӣв ҝв ҝв ҹв Ӣв ҖвўҖвЈјвЈҝвЈҝвЈҝв ҝвЈӯвЎүвўӣвЎғв Җв Җв Җв Җв Җв Җв Җ\nв Җв Җв Җв Җв ҖвЈҖвЈӨв ¶в ҝвЈҹвЈҹвЈқвЎ·вЈІвўӨвЈҖв Җв Җв Җв Җв Җв Җвў в Җв Җв Җв Җв Җв ҖвЈ вЈҫвЎҝв ғв №вЎҹвў–в ўв Ҫв Ұв Ғв Җв Җв Җв Җв Җв Җв Җ\nв Җв ҖвўҖвЈҙв һв Ғв Җв Җв Җв Җв Җв үв ҷвўҰвЈ•вЎҜвЈ·вЈ„в Җв Җв  вЈҙв Ӣвў“вЎ¶в Ӯв ҖвўҖвЈјвЈҝв ҹв Ғв Җв Җв Ҳв әвЎ„в ӢвЈҖвЈ°вЈҖв Җв Җв Җв Җв Җв Җ\nв ҖвЈ в ҹв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷвўҜвЈ’вўӯвЈҰв Җв Җвўёв •в Ұв Үв ҖвЈӨвЈҝвЎҝв ғвЈ в ҙв ¶в ¶вЈӨвЎҖв Җв Җв јв ҝвЎҸв Җв Җв Җв Җв Җв Җ\nвўҖвЎҸв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв »вЈқвЎ«вў§в Җв Җв Җв ҖвЈ вЈҫвЎҝв үв Җвўёв ҒвўҖвЈҖв Җв ҲвЈ·в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\nвЈјв Ғв Җв Җв Җв ҖвЈ вЈ¶вЈҝвЈҝвЈ·вЈҰвЎҖв Җв Җв Җв Җв ҷвЎ®вЈӣвЎҶв Җв ҖвЈ°вЈҝвЎҸвўҗвЎҖв Җв ёвЈҰвЈҖвЈЁв Үв ’вЈёвЈҖвЈҖвЈ„вЈҖвЎҖв Җв Җв Җв Җв Җв Җ\nвў№в Ҷв Җв Җв Җвў вЈҝвЎҝв ғв Җв Җв үвў»вЎ„в Җв Җв Җв Җв ҷвЈ—вўҝв ҖвЈёвЎҹвЎҷвў·вЎҲвў в ҖвЎҖв Ҳв үвЈҒв ҳвЈ в ҹв үв үв ҷвўҝвЈҝвЎҶв Җв Җв Җв Җв Җ\nв ҳвЈҮв Җв Җв Җв ҲвўҝвЎҮв ҖвўІв Җв Җв Җвў»вЎҖв ҖвўӨвЈҙвЎҖв №вЈҪвЈҙвЎҝвЈҒв Җв Ҳв »вЈҰвЈӨвЈҘвЈҢвЈЎвЎӨв һв Ғв ҖвЈ°в ӣв ҶвЈёвЈҝвЎҮв Җв Җв Җв Җв Җ"
                : visitorCard.color === "orange"
