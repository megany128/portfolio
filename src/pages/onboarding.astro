---
import DarkScene from "../layouts/DarkScene.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import VisitorCard from "../components/onboarding/VisitorCard.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { getCurrentVisitor, peekNextVisitorNumber } from "../lib/visitor-server";
import { SEED_VISITORS } from "../lib/seed-visitors";
import type { CardColor } from "../lib/visitor";

export const prerender = false;

const editMode = Astro.url.searchParams.has("edit");
const visitor = await getCurrentVisitor(Astro);
const nextNumber = await peekNextVisitorNumber(Astro);
const seedCount = SEED_VISITORS.length;
const displayNumber = visitor ? visitor.number + seedCount : nextNumber + seedCount;
const isEdit = editMode && visitor !== null;
const fromGallery = Astro.url.searchParams.get("from") === "gallery";

const PICKER_COLORS: CardColor[] = ["pink", "teal", "green", "orange"];
const startColor: CardColor =
  visitor?.color ?? PICKER_COLORS[Math.floor(Math.random() * PICKER_COLORS.length)];
---

{isEdit ? (
  <BaseLayout title="Edit card — Megan's World" showPet={false}>
    {/* Zero-size placeholders so the sidebar/footer view-transition groups
        resolve instantly instead of lingering from the gallery page. */}
    <div transition:name="sidebar" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;" />
    <div transition:name="footer" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;" />
    <VisitorCard
      nextNumber={displayNumber}
      edit
      existingName={visitor.name}
      startColor={startColor}
      existingSignature={visitor.signature}
    />
    <CustomCursor color={startColor} />
  </BaseLayout>
) : (
  <DarkScene title="Sign in — Megan's World">
    {/* Zero-size placeholders so the sidebar/footer view-transition groups
        resolve instantly when navigating from gallery or home. */}
    <div transition:name="sidebar" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;" />
    <div transition:name="footer" aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;" />
    <VisitorCard nextNumber={displayNumber} startColor={startColor} fromGallery={fromGallery} />
    <CustomCursor color={startColor} />
  </DarkScene>
)}
