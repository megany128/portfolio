<script>
  /* Section-entry fade — same pattern as splunk/lingofable */
  function initCaseStudyEntries() {
    const reduced = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
    const sections = Array.from(document.querySelectorAll<HTMLElement>(".cs-section"));
    if (sections.length === 0) return;

    if (reduced) {
      sections.forEach((s) => s.setAttribute("data-visible", ""));
      return;
    }

    let pending: HTMLElement[] = sections.slice();
    let scheduled = false;

    function check() {
      scheduled = false;
      const wh = window.innerHeight;
      pending = pending.filter((sec) => {
        const r = sec.getBoundingClientRect();
        if (r.top < wh - 40 && r.bottom > 0) {
          sec.setAttribute("data-visible", "");
          return false;
        }
        return true;
      });
    }
    function schedule() {
      if (scheduled) return;
      scheduled = true;
      if (document.visibilityState === "visible") {
        requestAnimationFrame(check);
      } else {
        setTimeout(check, 16);
      }
    }

    check();
    if (pending.length === 0) return;

    window.addEventListener("scroll", schedule, { passive: true });
    window.addEventListener("resize", schedule, { passive: true });

    setTimeout(() => {
      pending.forEach((s) => s.setAttribute("data-visible", ""));
      pending = [];
    }, 2000);
  }
  initCaseStudyEntries();
  document.addEventListener("astro:page-load", initCaseStudyEntries);

  /* Sneak peek unmute toggle */
  function initSneakUnmute() {
    const btn = document.querySelector<HTMLButtonElement>("[data-sneak-unmute]:not([data-wired])");
    const video = document.querySelector<HTMLVideoElement>("[data-sneak-video]");
    if (!btn || !video) return;
    btn.setAttribute("data-wired", "1");
    const iconMuted = btn.querySelector<HTMLElement>("[data-sneak-icon-muted]");
    const iconUnmuted = btn.querySelector<HTMLElement>("[data-sneak-icon-unmuted]");

    function syncIcons() {
      iconMuted?.classList.toggle("hidden", !video!.muted);
      iconUnmuted?.classList.toggle("hidden", video!.muted);
      btn!.setAttribute("aria-label", video!.muted ? "Unmute video" : "Mute video");
    }

    btn.addEventListener("click", () => {
      video.muted = !video.muted;
      video.play().catch(() => {});
      syncIcons();
    });
    syncIcons();
  }
  initSneakUnmute();
  document.addEventListener("astro:page-load", initSneakUnmute);

  /* Ideation pare-down toggle */
  function initPareToggle() {
    const wrap = document.querySelector<HTMLElement>("[data-pare]:not([data-wired])");
    if (!wrap) return;
    wrap.setAttribute("data-wired", "1");

    const frame = wrap.querySelector<HTMLElement>("[data-pare-frame]");
    const imgs = Array.from(wrap.querySelectorAll<HTMLImageElement>("[data-pare-img]"));
    const btn = wrap.querySelector<HTMLButtonElement>("[data-pare-toggle]");
    const btnLabel = wrap.querySelector<HTMLElement>("[data-pare-btn-label]");
    if (!frame || imgs.length < 2 || !btn || !btnLabel) return;

    let pared = false;
    btn.addEventListener("click", () => {
      pared = !pared;
      imgs.forEach((img) => {
        img.classList.toggle("is-active", img.dataset.pareImg === (pared ? "pared" : "initial"));
      });
      btnLabel.textContent = pared ? "← Show original" : "Pare it down →";
    });
  }
  initPareToggle();
  document.addEventListener("astro:page-load", initPareToggle);
</script>
