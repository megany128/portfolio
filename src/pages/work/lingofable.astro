<script>
  /*
    Section-entry fade. Uses a scroll listener (rAF-throttled) to mark each
    section visible once it enters the viewport from below. IntersectionObserver
    is avoided here for parity with the scrollspy — a single source of truth
    for "is this section on screen" works reliably in all environments.
    Once visible, sections stay visible (we don't re-animate on scroll-up).
  */
  function initCaseStudyEntries() {
    const reduced = window.matchMedia?.(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(".cs-section"),
    );
    if (sections.length === 0) return;

    if (reduced) {
      sections.forEach((s) => s.setAttribute("data-visible", ""));
      return;
    }

    let pending: HTMLElement[] = sections.slice();
    let scheduled = false;

    function check() {
      scheduled = false;
      const wh = window.innerHeight;
      pending = pending.filter((sec) => {
        const r = sec.getBoundingClientRect();
        // Reveal when any part of the section is in the viewport.
        if (r.top < wh - 40 && r.bottom > 0) {
          sec.setAttribute("data-visible", "");
          return false;
        }
        return true;
      });
    }
    function schedule() {
      if (scheduled) return;
      scheduled = true;
      if (document.visibilityState === "visible") {
        requestAnimationFrame(check);
      } else {
        setTimeout(check, 16);
      }
    }

    // Initial measurement.
    check();
    if (pending.length === 0) return;

    window.addEventListener("scroll", schedule, { passive: true });
    window.addEventListener("resize", schedule, { passive: true });

    // Safety: reveal everything after a short timeout so content is never
    // stuck at opacity:0 if the user's browser is being weird.
    setTimeout(() => {
      pending.forEach((s) => s.setAttribute("data-visible", ""));
      pending = [];
    }, 2000);
  }
  initCaseStudyEntries();
  document.addEventListener("astro:page-load", initCaseStudyEntries);
</script>
