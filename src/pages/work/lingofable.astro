---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudySidebar from "../../components/casestudy/CaseStudySidebar.astro";
import Footer from "../../components/home/Footer.astro";
import CustomCursor from "../../components/home/CustomCursor.astro";
import Tag from "../../components/ui/Tag.astro";
import { getCurrentVisitor } from "../../lib/visitor-server";

export const prerender = false;

const visitor = await getCurrentVisitor(Astro);
const cursorColor = visitor?.color ?? "pink";

// Sidebar sections — ids map 1:1 to the section elements below.
const tocSections = [
  { id: "context", label: "Context" },
  { id: "solution", label: "The solution" },
  { id: "features", label: "Features" },
  { id: "interaction", label: "Interaction design" },
  { id: "onboarding", label: "Onboarding & conversion" },
  { id: "reflection", label: "Reflection" },
];

const features = [
  {
    title: "Stories for every interest",
    body: "Explore fantasy, thriller, romance, and more. Always at your level.",
  },
  {
    title: "Tap any word, instantly understand",
    body: "Translations appear as you read, so you get to stay in the flow without any interruptions.",
  },
  {
    title: "Listen and read at the same time",
    body: "Follow along with audio narration for every fable. Read, listen, or both.",
  },
  {
    title: "Watch yourself improve",
    body: "Track your progress: CEFR level, words learned, reading streaks, and more.",
  },
];

const reflections = [
  {
    title: "Retention is the hardest part",
    body: "In order for users to actually appreciate your designs, they have to come back to the app in the first place! It's all about finding a core value loop and meeting your users where they are.",
  },
  {
    title: "Claude Code is my best friend!",
    body: "Honestly, I've become addicted to Claude Code. Iterating, polishing, and debugging is way easier with Claude Code, and I've learned how to best use subagents, worktrees, and MCP servers.",
  },
  {
    title: "Design extends beyond the app",
    body: "Before this, I had no idea just how important notifications were! They really do make a difference, from their copy to their frequency and time of day sent. Next up is widgets!",
  },
];
---

<BaseLayout title="Lingofable — Megan Yap">
  <div class="flex items-stretch min-h-screen" id="top">
    <CaseStudySidebar sections={tocSections} active="context" />

    <main class="flex-1 min-w-0 p-10 flex flex-col gap-14">
      <!-- Hero image -->
      <section class="cs-hero-wrap">
        <div class="cs-hero rounded-[24px] overflow-hidden">
          <img
            src="/images/work/lingofable/hero.png"
            alt="Lingofable — Language learning, one story at a time"
            loading="eager"
            class="block w-full h-auto object-cover"
          />
        </div>
      </section>

      <!-- Hero meta: tags, title, description -->
      <section class="flex flex-col gap-5">
        <div class="flex items-center gap-3">
          <Tag>Side Project</Tag>
          <Tag>Shipped</Tag>
        </div>
        <h1
          class="font-[family-name:var(--font-display)] font-light text-[40px] leading-[1.1] text-[var(--color-ink)] flex items-start gap-3"
        >
          <span aria-hidden="true" class="cs-hero-mark text-[var(--color-pink)]">✦</span>
          Building Lingofable from 0-1
        </h1>
        <p
          class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-relaxed max-w-[720px]"
        >
          I designed &amp; built Lingofable together with
          <a
            href="https://x.com"
            class="cs-mention text-[var(--color-ink)]"
            >@Simon Ilincev</a
          >
          as a passion project. It is a language app focused on learning through
          stories — we launched on the App Store in
          <span class="cs-emph" data-cs-emph>March 2026</span>, pitched to
          Pinterest&rsquo;s ex-CPO, and were featured on Cornell&rsquo;s
          <span class="cs-emph" data-cs-emph>Speaking of Language</span>
          podcast!
        </p>
      </section>

      <!-- Meta grid: role, team, timeline, skills -->
      <section
        class="grid grid-cols-2 md:grid-cols-4 gap-6 p-6 bg-[var(--color-bg-light)] rounded-[16px]"
      >
        <div class="flex flex-col gap-3">
          <p
            class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink)]"
          >
            Role
          </p>
          <p
            class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug"
          >
            Founder<br />Design Engineer<br />Marketing
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <p
            class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink)]"
          >
            Team
          </p>
          <p
            class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug"
          >
            Simon Ilincev (Co-Founder &amp; Software Engineer)
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <p
            class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink)]"
          >
            Timeline
          </p>
          <p
            class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug"
          >
            Oct 2025 &ndash; Apr 2026
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <p
            class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink)]"
          >
            Skills
          </p>
          <p
            class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-snug"
          >
            Vibe coding<br />Interaction design<br />Motion design
          </p>
        </div>
      </section>

      <!-- 01. Context -->
      <section id="context" data-cs-section class="flex flex-col gap-4 cs-section">
        <p
          class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink-dim)] tracking-wider"
        >
          Context
        </p>
        <h2
          class="font-[family-name:var(--font-display)] font-light text-[28px] text-[var(--color-ink)] leading-tight"
        >
          Language learning is tricky
        </h2>
        <p
          class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-relaxed max-w-[820px]"
        >
          Having learned Mandarin Chinese over the pandemic, I know from experience
          that language learning is tough. Engaging in native media is no doubt the
          best way to learn, but it&rsquo;s really difficult to find media that is
          both interesting and at your level.
        </p>
      </section>

      <!-- 02. The solution -->
      <section id="solution" data-cs-section class="flex flex-col gap-4 cs-section">
        <p
          class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink-dim)] tracking-wider"
        >
          The solution
        </p>
        <h2
          class="font-[family-name:var(--font-display)] font-light text-[28px] text-[var(--color-ink)] leading-tight"
        >
          Comprehensible input at scale, delivered through stories
        </h2>
        <p
          class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-relaxed max-w-[820px]"
        >
          The main thing that prevents learners from reading books in their target
          language is that most of the time, content is either 1) interesting but
          written for native speakers (and therefore linguistically complex), or 2)
          boring and written for children. As a solution, we built Lingofable to
          generate engaging stories that are exactly tailored towards readers —
          using the specific vocabulary they know, and written to complement their
          interests / favorite genres. This way, we can deliver stories that are at
          the perfect difficulty for learners to progress without feeling too much
          friction.
        </p>

        <!-- 2×2 feature-highlight grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-3">
          <!-- Card 1: From fairy tales to Reddit threads -->
          <article
            class="cs-solution-card cs-solution-card--neutral group relative rounded-[24px] bg-[#f6f4f3] p-6 pb-0 overflow-hidden h-[380px] flex flex-col"
          >
            <div class="flex flex-col gap-1 z-10">
              <h3
                class="font-[family-name:var(--font-body)] font-semibold text-[20px] text-[var(--color-ink)] text-center"
              >
                From fairy tales to Reddit threads
              </h3>
              <p
                class="font-[family-name:var(--font-body)] text-[14px] text-[var(--color-ink-dim)] text-center leading-snug"
              >
                Pick what you want to read. We&rsquo;ll match it to your level.
              </p>
            </div>
            <!-- Floating fable-card stack -->
            <div class="cs-fable-stack relative flex-1 mt-6">
              <div
                class="cs-fable-card cs-fable-card--back absolute left-0 bottom-0 w-[180px] rotate-[-8deg] rounded-[14px] overflow-hidden bg-white shadow-[0_4px_18px_-6px_rgba(36,36,36,0.25)]"
              >
                <img
                  src="/images/work/lingofable/fable-cover-2.png"
                  alt=""
                  loading="lazy"
                  class="w-full h-[92px] object-cover"
                />
                <p
                  class="px-3 pt-2 pb-3 font-[family-name:var(--font-body)] text-[11px] text-[var(--color-ink-dim)] leading-tight"
                >
                  <span class="text-[var(--color-ink)] font-medium">The Whispering Wood</span><br
                  />Lira isn&rsquo;t lost&hellip;
                </p>
              </div>
              <div
                class="cs-fable-card cs-fable-card--right absolute right-0 top-4 w-[200px] rotate-[6deg] rounded-[14px] overflow-hidden bg-white shadow-[0_4px_18px_-6px_rgba(36,36,36,0.25)]"
              >
                <div class="h-[70px] bg-gradient-to-br from-[var(--color-bg-neutral)] to-[var(--color-bg-neutral-2)] flex items-center justify-center">
                  <span
                    class="font-[family-name:var(--font-mono)] text-[10px] uppercase text-[var(--color-ink-dim)]"
                  >r/AITA</span>
                </div>
                <p
                  class="px-3 pt-2 pb-3 font-[family-name:var(--font-body)] text-[11px] text-[var(--color-ink-dim)] leading-tight"
                >
                  &hellip;sing to share my secret recipe with my&hellip;
                </p>
              </div>
              <div
                class="cs-fable-card cs-fable-card--front absolute left-1/2 -translate-x-1/2 bottom-[-32px] w-[220px] rotate-[-2deg] rounded-[16px] overflow-hidden bg-white shadow-[0_14px_28px_-12px_rgba(36,36,36,0.35)] z-10"
              >
                <img
                  src="/images/work/lingofable/fable-cover-3.png"
                  alt=""
                  loading="lazy"
                  class="w-full h-[120px] object-cover"
                />
                <div class="px-3 pt-2 pb-3 flex flex-col gap-1">
                  <div class="flex items-center gap-2">
                    <span
                      class="inline-flex items-center gap-1 font-[family-name:var(--font-body)] text-[10px] px-2 py-[2px] rounded-full bg-[var(--color-green-1)]/40 text-[var(--color-green)]"
                    >🌱 Just right</span>
                    <span
                      class="font-[family-name:var(--font-mono)] text-[9px] uppercase text-[var(--color-ink-dim)]"
                    >Romance</span>
                  </div>
                  <p
                    class="font-[family-name:var(--font-body)] text-[13px] text-[var(--color-ink)] font-medium leading-tight"
                  >Light to Light</p>
                  <p
                    class="font-[family-name:var(--font-body)] text-[11px] text-[var(--color-ink-dim)] leading-snug"
                  >He tends the lighthouse alone. She walks the beach every evening.</p>
                </div>
              </div>
            </div>
          </article>

          <!-- Card 2: Track your progress -->
          <article
            class="cs-solution-card cs-solution-card--neutral group relative rounded-[24px] bg-[#efe9d9] p-6 overflow-hidden h-[380px] flex flex-col justify-between"
          >
            <div class="flex flex-col gap-1">
              <h3
                class="font-[family-name:var(--font-body)] font-semibold text-[20px] text-[var(--color-ink)]"
              >
                Track your progress
              </h3>
              <p
                class="font-[family-name:var(--font-body)] text-[14px] text-[var(--color-ink-dim)] leading-snug max-w-[280px]"
              >
                See your CEFR level rise and your vocabulary grow as you read.
              </p>
            </div>
            <div class="relative h-[250px]">
              <!-- Progress pie card -->
              <div
                class="cs-progress-pie absolute right-0 top-0 w-[160px] rounded-[12px] bg-white p-3 shadow-[0_6px_18px_-10px_rgba(36,36,36,0.2)]"
              >
                <div class="flex flex-col gap-1 mb-2">
                  <p
                    class="font-[family-name:var(--font-body)] text-[10px] text-[var(--color-ink-dim)] flex items-center justify-between"
                  >
                    Words Read Level <span>?</span>
                  </p>
                  <p
                    class="font-[family-name:var(--font-body)] text-[9px] text-[var(--color-ink-mute)]"
                  >Vocabulary breakdown</p>
                </div>
                <div class="flex items-center gap-2">
                  <div
                    class="cs-pie relative w-[60px] h-[60px] rounded-full"
                    style="background: conic-gradient(var(--color-pink) 0 40%, var(--color-teal) 40% 70%, var(--color-orange) 70% 90%, var(--color-green) 90% 100%);"
                  >
                    <div
                      class="absolute inset-[10px] rounded-full bg-white flex flex-col items-center justify-center"
                    >
                      <p
                        class="font-[family-name:var(--font-body)] font-semibold text-[11px] text-[var(--color-ink)]"
                      >
                        100
                      </p>
                      <p
                        class="font-[family-name:var(--font-body)] text-[8px] text-[var(--color-ink-dim)] leading-none"
                      >words</p>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-1">
                      <span class="w-2 h-2 rounded-full bg-[var(--color-pink)]"></span>
                      <span
                        class="font-[family-name:var(--font-body)] text-[9px] text-[var(--color-ink-dim)]"
                      >A2: 16</span>
                    </div>
                    <div class="flex items-center gap-1">
                      <span class="w-2 h-2 rounded-full bg-[var(--color-teal)]"></span>
                      <span
                        class="font-[family-name:var(--font-body)] text-[9px] text-[var(--color-ink-dim)]"
                      >B1: 9</span>
                    </div>
                  </div>
                </div>
                <p
                  class="font-[family-name:var(--font-body)] text-[9px] text-[var(--color-pink)] mt-2"
                >Learn more about CEFR levels →</p>
              </div>

              <!-- Reading activity heatmap -->
              <div
                class="cs-progress-heatmap absolute left-0 top-8 w-[180px] rounded-[12px] bg-white p-3 shadow-[0_6px_18px_-10px_rgba(36,36,36,0.2)]"
              >
                <p
                  class="font-[family-name:var(--font-body)] text-[10px] text-[var(--color-ink-dim)] mb-2"
                >Reading activity</p>
                <div class="flex gap-[2px] text-[8px] text-[var(--color-ink-mute)] mb-1">
                  <span class="w-[66%]">Jan &nbsp; Feb &nbsp; Mar</span>
                </div>
                <div class="grid grid-cols-13 gap-[2px]">
                  {Array.from({ length: 13 * 7 }).map((_, i) => {
                    const r = (i * 1301 + 7) % 100;
                    let bg = "bg-[var(--color-bg-neutral-2)]";
                    if (r > 70) bg = "bg-[var(--color-green)]";
                    else if (r > 50) bg = "bg-[var(--color-green-0)]";
                    else if (r > 30) bg = "bg-[var(--color-green-1)]";
                    else if (r > 18) bg = "bg-[var(--color-green-2)]/40";
                    return <span class={`w-[8px] h-[8px] rounded-[2px] ${bg}`}></span>;
                  })}
                </div>
                <div class="flex gap-1 mt-2 text-[8px] text-[var(--color-ink-mute)] items-center">
                  <span>Less</span>
                  <span class="w-[6px] h-[6px] rounded-[1px] bg-[var(--color-bg-neutral-2)]"></span>
                  <span class="w-[6px] h-[6px] rounded-[1px] bg-[var(--color-green-1)]"></span>
                  <span class="w-[6px] h-[6px] rounded-[1px] bg-[var(--color-green-0)]"></span>
                  <span class="w-[6px] h-[6px] rounded-[1px] bg-[var(--color-green)]"></span>
                  <span>More</span>
                </div>
              </div>

              <!-- Words learned line chart -->
              <div
                class="cs-progress-chart absolute left-0 bottom-0 w-[170px] rounded-[12px] bg-white p-3 shadow-[0_6px_18px_-10px_rgba(36,36,36,0.2)]"
              >
                <p
                  class="font-[family-name:var(--font-body)] text-[10px] text-[var(--color-ink-dim)]"
                >Words learned</p>
                <p
                  class="font-[family-name:var(--font-body)] text-[8px] text-[var(--color-ink-mute)] mb-2"
                >35 words over 6 active days</p>
                <svg viewBox="0 0 120 40" class="w-full h-[40px]" aria-hidden="true">
                  <polyline
                    fill="none"
                    stroke="var(--color-green)"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    points="0,32 20,26 40,30 60,18 80,20 100,10 120,6"
                  />
                </svg>
              </div>
            </div>
          </article>

          <!-- Card 3: Always at the perfect i+1 difficulty (full width on desktop) -->
          <article
            class="cs-solution-card cs-solution-card--green group relative rounded-[24px] bg-[#dceecf] p-6 overflow-hidden h-[240px] md:col-span-2 flex items-center gap-8"
          >
            <div class="flex flex-col gap-2 max-w-[420px] z-10">
              <h3
                class="font-[family-name:var(--font-body)] font-semibold text-[20px] text-[var(--color-ink)]"
              >
                Always at the perfect i+1 difficulty
              </h3>
              <p
                class="font-[family-name:var(--font-body)] text-[14px] text-[var(--color-ink-dim)] leading-snug"
              >
                Stories adapt to your level — never too hard, never too easy.
              </p>
            </div>
            <div class="relative flex-1 h-full min-w-0">
              <!-- Progress metrics card -->
              <div
                class="cs-metric-card absolute left-0 top-1/2 -translate-y-1/2 w-[240px] rounded-[12px] bg-white p-3 shadow-[0_8px_22px_-10px_rgba(36,36,36,0.2)]"
              >
                <div class="grid grid-cols-3 gap-3 mb-2">
                  <div>
                    <p
                      class="font-[family-name:var(--font-body)] text-[8px] text-[var(--color-ink-mute)] uppercase"
                    >CEFR level</p>
                    <p
                      class="font-[family-name:var(--font-body)] font-semibold text-[16px] text-[var(--color-ink)]"
                    >A1</p>
                  </div>
                  <div>
                    <p
                      class="font-[family-name:var(--font-body)] text-[8px] text-[var(--color-ink-mute)] uppercase"
                    >Fables read</p>
                    <p
                      class="font-[family-name:var(--font-body)] font-semibold text-[16px] text-[var(--color-ink)]"
                    >41 <span class="text-[9px] text-[var(--color-green)]">+1</span></p>
                  </div>
                  <div>
                    <p
                      class="font-[family-name:var(--font-body)] text-[8px] text-[var(--color-ink-mute)] uppercase"
                    >Words known</p>
                    <p
                      class="font-[family-name:var(--font-body)] font-semibold text-[16px] text-[var(--color-ink)]"
                    >340 <span class="text-[9px] text-[var(--color-green)]">+7</span></p>
                  </div>
                </div>
                <p
                  class="font-[family-name:var(--font-body)] text-[9px] text-[var(--color-ink-dim)] mb-1"
                >Only 200 words until <span class="font-semibold text-[var(--color-ink)]">A2 (upper beginner)</span>!</p>
                <div class="h-[4px] w-full rounded-full bg-[var(--color-bg-neutral-2)]/60 overflow-hidden">
                  <div
                    class="h-full bg-[var(--color-orange)] rounded-full"
                    style="width: 55%;"
                  ></div>
                </div>
              </div>
              <!-- Floating speech bubble -->
              <div
                class="cs-solution-bubble absolute right-[72px] top-4 px-4 py-2 bg-white rounded-[16px] shadow-[0_6px_16px_-8px_rgba(36,36,36,0.3)] text-center"
              >
                <p
                  class="font-[family-name:var(--font-body)] text-[12px] text-[var(--color-ink)] italic"
                >Finding the perfect fables for you&hellip;</p>
              </div>
              <!-- Mascot leaf with magnifier -->
              <img
                src="/images/work/lingofable/mascot-leaf.png"
                alt=""
                loading="lazy"
                class="cs-solution-mascot absolute right-0 bottom-0 h-[160px] w-auto object-contain"
              />
              <img
                src="/images/work/lingofable/mascot-magnifier.png"
                alt=""
                loading="lazy"
                class="cs-solution-magnifier absolute right-[40px] bottom-[90px] h-[50px] w-auto object-contain"
              />
            </div>
          </article>
        </div>
      </section>

      <!-- 03. Features -->
      <section id="features" data-cs-section class="flex flex-col gap-4 cs-section">
        <p
          class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink-dim)] tracking-wider"
        >
          Features
        </p>
        <h2
          class="font-[family-name:var(--font-display)] font-light text-[28px] text-[var(--color-ink)] leading-tight"
        >
          Designed to help learners make real progress
        </h2>
        <p
          class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-relaxed max-w-[820px]"
        >
          Users are able to browse a library of stories in their target language,
          and track weekly goals to keep on track with their learning. The library
          refreshes regularly to keep the most relevant stories at the top for
          readers.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-10 mt-4 items-center">
          <div class="flex flex-col gap-3 max-w-[380px]">
            {
              features.map((feature) => (
                <div
                  class="cs-feature-tile bg-[var(--color-bg-light)] rounded-[16px] p-4 flex flex-col gap-1.5 transition-transform duration-[var(--duration-base)] ease-[var(--ease-out-soft)] hover:-translate-y-0.5"
                >
                  <h3 class="font-[family-name:var(--font-body)] font-semibold text-[16px] text-[var(--color-ink)]">
                    {feature.title}
                  </h3>
                  <p class="font-[family-name:var(--font-body)] text-[14px] text-[var(--color-ink-dim)] leading-snug">
                    {feature.body}
                  </p>
                </div>
              ))
            }
          </div>
          <div class="cs-features-phone-wrap self-center justify-self-center md:justify-self-end">
            <img
              src="/images/work/lingofable/features-phone.png"
              alt="Lingofable app library screen showing a grid of fable cards"
              loading="lazy"
              class="cs-features-phone max-w-[300px] w-full h-auto rounded-[28px]"
            />
          </div>
        </div>
      </section>

      <!-- 04. Interaction design -->
      <section id="interaction" data-cs-section class="flex flex-col gap-4 cs-section">
        <p
          class="font-[family-name:var(--font-mono)] text-sm uppercase text-[var(--color-ink-dim)] tracking-wider"
        >
          Interaction design
        </p>
        <h2
          class="font-[family-name:var(--font-display)] font-light text-[28px] text-[var(--color-ink)] leading-tight"
        >
          Teaching users how to interact
        </h2>
        <p
          class="font-[family-name:var(--font-body)] text-base text-[var(--color-ink-dim)] leading-relaxed max-w-[820px]"
        >
          During our beta testing, users told us that interacting with the reading
          page was confusing. Although this is a standard interaction pattern in
          other apps such as Du Chinese, many users had not encountered such apps
          before. Using Lottielab, I created two different tutorial animations that
          would play when the user opened a story for the first time.
        </p>

        <div
